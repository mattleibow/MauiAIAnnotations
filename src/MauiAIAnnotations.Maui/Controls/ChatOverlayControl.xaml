<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:MauiAIAnnotations.Maui.Controls"
             x:Class="MauiAIAnnotations.Maui.Controls.ChatOverlayControl"
             x:Name="Self">

    <Grid>
        <!-- FAB Chat Button (hidden in sidebar mode) -->
        <Button x:Name="ChatFab"
                Text="💬"
                AutomationId="ChatFabButton"
                Clicked="OnOpenChatClicked"
                BackgroundColor="#5B8C5A"
                TextColor="White"
                FontSize="24"
                WidthRequest="56"
                HeightRequest="56"
                CornerRadius="28"
                HorizontalOptions="End"
                VerticalOptions="End"
                Margin="0,0,20,20" />

        <!-- Chat Popup Overlay (narrow screens) -->
        <Grid x:Name="ChatOverlay"
              AutomationId="ChatOverlayPanel"
              IsVisible="False"
              BackgroundColor="#66000000">

            <Grid.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnChatBackdropTapped" />
            </Grid.GestureRecognizers>

            <Border x:Name="OverlayBorder"
                    VerticalOptions="Fill"
                    HorizontalOptions="End"
                    WidthRequest="420"
                    Margin="0"
                    Padding="0"
                    InputTransparent="False"
                    Stroke="{AppThemeBinding Light=#E8E0D4, Dark=#3D3930}"
                    StrokeThickness="1"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#2A2721}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="0" />
                </Border.StrokeShape>

                <Grid RowDefinitions="Auto,*" RowSpacing="0">
                    <!-- Chat Header -->
                    <Border Grid.Row="0"
                            BackgroundColor="#5B8C5A"
                            Padding="16,14"
                            StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="0" />
                        </Border.StrokeShape>
                        <Grid ColumnDefinitions="*,Auto,Auto">
                            <Label Text="&#x1F33F; Chat Assistant"
                                   FontSize="17" FontAttributes="Bold"
                                   TextColor="White" VerticalOptions="Center" />
                            <Button Grid.Column="1" Text="&#x1F5D1;" FontSize="14"
                                    AutomationId="ClearChatButton"
                                    BackgroundColor="Transparent" TextColor="#D4E8D4"
                                    Command="{Binding ChatVM.ClearCommand, Source={x:Reference Self}}"
                                    Padding="8,4" MinimumWidthRequest="40"
                                    ToolTipProperties.Text="Clear chat" />
                            <Button Grid.Column="2" Text="&#x2715;" FontSize="16"
                                    AutomationId="CloseChatButton"
                                    BackgroundColor="Transparent" TextColor="#D4E8D4"
                                    Clicked="OnCloseChatClicked"
                                    Padding="8,4" MinimumWidthRequest="40" />
                        </Grid>
                    </Border>

                    <!-- Inner ChatPanelControl -->
                    <controls:ChatPanelControl x:Name="InnerChatPanel"
                                               Grid.Row="1"
                                               ChatVM="{Binding ChatVM, Source={x:Reference Self}}" />
                </Grid>
            </Border>
        </Grid>

        <!-- Sidebar panel (wide screens — always visible when open) -->
        <Border x:Name="SidebarPanel"
                IsVisible="False"
                HorizontalOptions="End"
                VerticalOptions="Fill"
                WidthRequest="400"
                Margin="0"
                Padding="0"
                InputTransparent="False"
                Stroke="{AppThemeBinding Light=#E8E0D4, Dark=#3D3930}"
                StrokeThickness="1"
                BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#2A2721}">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="0" />
            </Border.StrokeShape>

            <Grid RowDefinitions="Auto,*" RowSpacing="0">
                <!-- Sidebar Header -->
                <Border Grid.Row="0"
                        BackgroundColor="#5B8C5A"
                        Padding="16,14"
                        StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="0" />
                    </Border.StrokeShape>
                    <Grid ColumnDefinitions="*,Auto,Auto">
                        <Label Text="&#x1F33F; Chat Assistant"
                               FontSize="17" FontAttributes="Bold"
                               TextColor="White" VerticalOptions="Center" />
                        <Button Grid.Column="1" Text="&#x1F5D1;" FontSize="14"
                                AutomationId="SidebarClearChatButton"
                                BackgroundColor="Transparent" TextColor="#D4E8D4"
                                Command="{Binding ChatVM.ClearCommand, Source={x:Reference Self}}"
                                Padding="8,4" MinimumWidthRequest="40"
                                ToolTipProperties.Text="Clear chat" />
                        <Button Grid.Column="2" Text="&#x2715;" FontSize="16"
                                AutomationId="SidebarCloseChatButton"
                                BackgroundColor="Transparent" TextColor="#D4E8D4"
                                Clicked="OnCloseChatClicked"
                                Padding="8,4" MinimumWidthRequest="40" />
                    </Grid>
                </Border>

                <!-- Inner ChatPanelControl (sidebar) -->
                <controls:ChatPanelControl x:Name="SidebarChatPanel"
                                           Grid.Row="1"
                                           ChatVM="{Binding ChatVM, Source={x:Reference Self}}" />
            </Grid>
        </Border>
    </Grid>

</ContentView>
