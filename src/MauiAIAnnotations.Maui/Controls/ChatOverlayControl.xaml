<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:MauiAIAnnotations.Maui.Controls"
             x:Class="MauiAIAnnotations.Maui.Controls.ChatOverlayControl"
             x:Name="Self">

    <Grid>
        <!-- FAB Chat Button -->
        <Button Text="💬"
                Clicked="OnOpenChatClicked"
                BackgroundColor="#5B8C5A"
                TextColor="White"
                FontSize="24"
                WidthRequest="56"
                HeightRequest="56"
                CornerRadius="28"
                HorizontalOptions="End"
                VerticalOptions="End"
                Margin="0,0,20,20" />

        <!-- Chat Popup Overlay -->
        <Grid x:Name="ChatOverlay"
              IsVisible="False"
              BackgroundColor="#66000000">

            <Grid.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnChatBackdropTapped" />
            </Grid.GestureRecognizers>

            <Border VerticalOptions="End"
                    HorizontalOptions="Fill"
                    HeightRequest="500"
                    Margin="12,0,12,12"
                    Padding="0"
                    InputTransparent="False"
                    Stroke="{AppThemeBinding Light=#E8E0D4, Dark=#3D3930}"
                    StrokeThickness="1"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#2A2721}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20,20,12,12" />
                </Border.StrokeShape>

                <Grid RowDefinitions="Auto,*" RowSpacing="0">
                    <!-- Chat Header -->
                    <Border Grid.Row="0"
                            BackgroundColor="#5B8C5A"
                            Padding="16,14"
                            StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="20,20,0,0" />
                        </Border.StrokeShape>
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="&#x1F33F; Chat Assistant"
                                   FontSize="17" FontAttributes="Bold"
                                   TextColor="White" VerticalOptions="Center" />
                            <Button Grid.Column="1" Text="&#x2715;" FontSize="16"
                                    BackgroundColor="Transparent" TextColor="#D4E8D4"
                                    Clicked="OnCloseChatClicked"
                                    Padding="8,4" MinimumWidthRequest="40" />
                        </Grid>
                    </Border>

                    <!-- Inner ChatPanelControl -->
                    <controls:ChatPanelControl x:Name="InnerChatPanel"
                                               Grid.Row="1"
                                               ChatVM="{Binding ChatVM, Source={x:Reference Self}}" />
                </Grid>
            </Border>
        </Grid>
    </Grid>

</ContentView>
