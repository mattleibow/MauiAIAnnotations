<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAIAnnotations.Maui.Views.FunctionResultView">
    <Grid Padding="0,2">
        <Border Padding="10,6" HorizontalOptions="Start"
                BackgroundColor="{AppThemeBinding Light=#EDF6EC, Dark=#1A251A}"
                StrokeThickness="0" Opacity="0.85">
            <Border.StrokeShape><RoundRectangle CornerRadius="10" /></Border.StrokeShape>
            <Label Text="{Binding Content.Result}" FontSize="11" LineBreakMode="WordWrap"
                   MaximumWidthRequest="300"
                   TextColor="{AppThemeBinding Light=#7A7062, Dark=#A69E90}" />
        </Border>
    </Grid>
</ContentView>
