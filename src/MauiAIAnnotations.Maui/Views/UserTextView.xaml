<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAIAnnotations.Maui.Views.UserTextView">
    <Grid Padding="0,4">
        <Border Padding="12,10" MaximumWidthRequest="340"
                HorizontalOptions="End"
                BackgroundColor="#5B8C5A"
                StrokeThickness="0">
            <Border.StrokeShape><RoundRectangle CornerRadius="16,16,4,16" /></Border.StrokeShape>
            <Label Text="{Binding Content.Text}" FontSize="14" TextColor="White" />
        </Border>
    </Grid>
</ContentView>
