<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAIAnnotations.Maui.Views.FunctionCallView">
    <Grid Padding="0,2">
        <Border Padding="10,6" HorizontalOptions="Start"
                BackgroundColor="{AppThemeBinding Light=#E8E0D4, Dark=#2A2620}"
                StrokeThickness="0" Opacity="0.85">
            <Border.StrokeShape><RoundRectangle CornerRadius="10" /></Border.StrokeShape>
            <HorizontalStackLayout Spacing="6">
                <Label Text="&#x2699;&#xFE0F;" FontSize="12" VerticalOptions="Center" />
                <Label Text="{Binding Content.Name, StringFormat='Calling {0}...'}" FontSize="12" FontAttributes="Italic"
                       TextColor="{AppThemeBinding Light=#7A7062, Dark=#A69E90}" />
            </HorizontalStackLayout>
        </Border>
    </Grid>
</ContentView>
