<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:chat="clr-namespace:MauiAIAnnotations.Maui.Chat"
             x:Class="MauiAIAnnotations.Maui.Chat.DefaultContentView"
             x:DataType="chat:ContentContext">
    <Grid>
        <Label Text="{Binding DisplayText}" FontSize="13" Padding="4"
               TextColor="{AppThemeBinding Light=#7A7062, Dark=#A69E90}" />
    </Grid>
</ContentView>
