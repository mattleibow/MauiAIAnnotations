<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAIAnnotations.Maui.Chat.ErrorView">
    <Grid x:Name="InnerContent" Padding="0,4">
        <Border Padding="12,10" MaximumWidthRequest="340"
                HorizontalOptions="Start"
                BackgroundColor="{AppThemeBinding Light=#FDE8E8, Dark=#2A1818}"
                StrokeThickness="0">
            <Border.StrokeShape><RoundRectangle CornerRadius="12" /></Border.StrokeShape>
            <Label Text="{Binding Message}" FontSize="14" TextColor="#C75050" />
        </Border>
    </Grid>
</ContentView>
