<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                    xmlns:chat="clr-namespace:MauiAIAnnotations.Maui.Chat"
                    x:Class="MauiAIAnnotations.Maui.Themes.ChatTheme">

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- Design Tokens — Colors                                        -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <Color x:Key="MauiAI.User.Background">#5B8C5A</Color>
    <Color x:Key="MauiAI.User.TextColor">White</Color>
    <Color x:Key="MauiAI.Assistant.Background">#F0EBE3</Color>
    <Color x:Key="MauiAI.Assistant.TextColor">#2C2416</Color>
    <Color x:Key="MauiAI.FunctionCall.Background">#E8E0D4</Color>
    <Color x:Key="MauiAI.FunctionCall.TextColor">#7A7062</Color>
    <Color x:Key="MauiAI.FunctionResult.Background">#EDF6EC</Color>
    <Color x:Key="MauiAI.FunctionResult.TextColor">#7A7062</Color>
    <Color x:Key="MauiAI.Error.Background">#FDE8E8</Color>
    <Color x:Key="MauiAI.Error.TextColor">#C75050</Color>
    <Color x:Key="MauiAI.Default.TextColor">#7A7062</Color>
    <Color x:Key="MauiAI.Approval.Background">#FFFBF0</Color>
    <Color x:Key="MauiAI.Approval.Border">#E8D9B5</Color>
    <Color x:Key="MauiAI.Approval.HeaderColor">#8B7340</Color>
    <Color x:Key="MauiAI.Button.Approve">#5B8C5A</Color>
    <Color x:Key="MauiAI.Button.Reject">#C75050</Color>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- ControlTemplate: ChatMessageView (User + Assistant)           -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <ControlTemplate x:Key="MauiAI.ChatMessageTemplate">
        <Grid Padding="0,4">
            <VisualStateManager.VisualStateGroups>
                <VisualStateGroup x:Name="RoleStates">
                    <VisualState x:Name="User">
                        <VisualState.Setters>
                            <Setter TargetName="MessageBorder" Property="Border.BackgroundColor"
                                    Value="{DynamicResource MauiAI.User.Background}" />
                            <Setter TargetName="MessageBorder" Property="Border.HorizontalOptions"
                                    Value="End" />
                            <Setter TargetName="MessageLabel" Property="Label.TextColor"
                                    Value="{DynamicResource MauiAI.User.TextColor}" />
                            <Setter TargetName="MessageShape" Property="RoundRectangle.CornerRadius"
                                    Value="16,16,4,16" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="Assistant">
                        <VisualState.Setters>
                            <Setter TargetName="MessageBorder" Property="Border.BackgroundColor"
                                    Value="{DynamicResource MauiAI.Assistant.Background}" />
                            <Setter TargetName="MessageBorder" Property="Border.HorizontalOptions"
                                    Value="Start" />
                            <Setter TargetName="MessageLabel" Property="Label.TextColor"
                                    Value="{DynamicResource MauiAI.Assistant.TextColor}" />
                            <Setter TargetName="MessageShape" Property="RoundRectangle.CornerRadius"
                                    Value="16,16,16,4" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateManager.VisualStateGroups>

            <Border x:Name="MessageBorder" Padding="12,10" MaximumWidthRequest="340"
                    HorizontalOptions="Start"
                    BackgroundColor="{DynamicResource MauiAI.Assistant.Background}"
                    StrokeThickness="0">
                <Border.StrokeShape>
                    <RoundRectangle x:Name="MessageShape" CornerRadius="16,16,16,4" />
                </Border.StrokeShape>
                <Label x:Name="MessageLabel"
                       Text="{TemplateBinding Text}" FontSize="14"
                       TextColor="{DynamicResource MauiAI.Assistant.TextColor}" />
            </Border>
        </Grid>
    </ControlTemplate>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- ControlTemplate: FunctionCallMessageView                      -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <ControlTemplate x:Key="MauiAI.FunctionCallTemplate">
        <Grid Padding="0,2">
            <Border Padding="10,6" HorizontalOptions="Start"
                    BackgroundColor="{DynamicResource MauiAI.FunctionCall.Background}"
                    StrokeThickness="0" Opacity="0.85">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10" />
                </Border.StrokeShape>
                <HorizontalStackLayout Spacing="6">
                    <Label Text="⚙️" FontSize="12" VerticalOptions="Center" />
                    <Label Text="{TemplateBinding FunctionName, StringFormat='Calling {0}...'}"
                           FontSize="12" FontAttributes="Italic"
                           TextColor="{DynamicResource MauiAI.FunctionCall.TextColor}" />
                </HorizontalStackLayout>
            </Border>
        </Grid>
    </ControlTemplate>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- ControlTemplate: FunctionResultMessageView                    -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <ControlTemplate x:Key="MauiAI.FunctionResultTemplate">
        <Grid Padding="0,2">
            <Border Padding="10,6" HorizontalOptions="Start"
                    BackgroundColor="{DynamicResource MauiAI.FunctionResult.Background}"
                    StrokeThickness="0" Opacity="0.85">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10" />
                </Border.StrokeShape>
                <Label Text="{TemplateBinding ResultText}" FontSize="11"
                       LineBreakMode="WordWrap" MaximumWidthRequest="300"
                       TextColor="{DynamicResource MauiAI.FunctionResult.TextColor}" />
            </Border>
        </Grid>
    </ControlTemplate>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- ControlTemplate: ErrorMessageView                             -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <ControlTemplate x:Key="MauiAI.ErrorTemplate">
        <Grid Padding="0,4">
            <Border Padding="12,10" MaximumWidthRequest="340" HorizontalOptions="Start"
                    BackgroundColor="{DynamicResource MauiAI.Error.Background}" StrokeThickness="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12" />
                </Border.StrokeShape>
                <Label Text="{TemplateBinding ErrorMessageText}" FontSize="14"
                       TextColor="{DynamicResource MauiAI.Error.TextColor}" />
            </Border>
        </Grid>
    </ControlTemplate>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- ControlTemplate: DefaultMessageView                           -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <ControlTemplate x:Key="MauiAI.DefaultTemplate">
        <Grid>
            <Label Text="{TemplateBinding DisplayText}" FontSize="13" Padding="4"
                   TextColor="{DynamicResource MauiAI.Default.TextColor}" />
        </Grid>
    </ControlTemplate>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- Implicit Styles — wire ControlTemplate via DynamicResource     -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <Style TargetType="chat:ChatMessageView">
        <Setter Property="ControlTemplate" Value="{DynamicResource MauiAI.ChatMessageTemplate}" />
    </Style>

    <Style TargetType="chat:FunctionCallMessageView">
        <Setter Property="ControlTemplate" Value="{DynamicResource MauiAI.FunctionCallTemplate}" />
    </Style>

    <Style TargetType="chat:FunctionResultMessageView">
        <Setter Property="ControlTemplate" Value="{DynamicResource MauiAI.FunctionResultTemplate}" />
    </Style>

    <Style TargetType="chat:ErrorMessageView">
        <Setter Property="ControlTemplate" Value="{DynamicResource MauiAI.ErrorTemplate}" />
    </Style>

    <Style TargetType="chat:DefaultMessageView">
        <Setter Property="ControlTemplate" Value="{DynamicResource MauiAI.DefaultTemplate}" />
    </Style>

</ResourceDictionary>
