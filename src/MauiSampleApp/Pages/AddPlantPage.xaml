<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiSampleApp.Pages.AddPlantPage"
             Title="Add Plant">

    <ScrollView Padding="16">
        <VerticalStackLayout Spacing="16">

            <!-- Header -->
            <Label Text="🌱 Add a New Plant" FontSize="24" FontAttributes="Bold" />
            <Label Text="Tell us about your new plant friend!"
                   FontSize="14"
                   TextColor="{AppThemeBinding Light='#666', Dark='#AAA'}" />

            <!-- Form -->
            <Border Padding="16"
                    Stroke="{AppThemeBinding Light='#E0E0E0', Dark='#404040'}"
                    StrokeThickness="1"
                    BackgroundColor="{AppThemeBinding Light='#FAFAFA', Dark='#2A2A2A'}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="14">

                    <VerticalStackLayout Spacing="4">
                        <Label Text="Nickname *" FontSize="13" FontAttributes="Bold" />
                        <Entry Placeholder="e.g. My Tomatoes"
                               Text="{Binding Nickname}"
                               AutomationId="NicknameEntry" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="4">
                        <Label Text="Species *" FontSize="13" FontAttributes="Bold" />
                        <Entry Placeholder="e.g. tomato, basil, rose"
                               Text="{Binding Species}"
                               AutomationId="SpeciesEntry" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="4">
                        <Label Text="Location" FontSize="13" FontAttributes="Bold" />
                        <Entry Placeholder="e.g. Back garden, Kitchen windowsill"
                               Text="{Binding Location}"
                               AutomationId="LocationEntry" />
                    </VerticalStackLayout>

                    <Grid ColumnDefinitions="*,Auto" Padding="0,4">
                        <Label Text="Indoor plant?" FontSize="14" VerticalOptions="Center" />
                        <Switch Grid.Column="1" IsToggled="{Binding IsIndoor}" AutomationId="IndoorSwitch" />
                    </Grid>

                </VerticalStackLayout>
            </Border>

            <!-- Status -->
            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" />
            <Label Text="{Binding StatusMessage}"
                   FontSize="13"
                   TextColor="{AppThemeBinding Light='#666', Dark='#AAA'}"
                   IsVisible="{Binding IsBusy}" />

            <!-- Save button -->
            <Button Text="🌿 Add Plant"
                    Command="{Binding SaveCommand}"
                    BackgroundColor="#2E7D32"
                    TextColor="White"
                    FontSize="16"
                    CornerRadius="8"
                    HeightRequest="50"
                    AutomationId="SavePlantButton" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
