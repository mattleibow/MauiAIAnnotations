<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MauiSampleApp.ViewModels"
             xmlns:models="clr-namespace:MauiSampleApp.Core.Models;assembly=MauiSampleApp.Core"
             x:Class="MauiSampleApp.MainPage"
             Title="🌱 Garden Helper">

    <ContentPage.Resources>
    </ContentPage.Resources>

    <Grid>
        <!-- Main Content -->
        <Grid RowDefinitions="Auto,*,Auto" Padding="16" RowSpacing="12">

            <!-- Header -->
            <VerticalStackLayout Grid.Row="0" Spacing="4">
                <Label Text="🌱 My Garden"
                       FontSize="28"
                       FontAttributes="Bold"
                       AutomationId="PageTitle" />
                <Label Text="Chat with your AI gardening assistant to add plants and track care."
                       FontSize="14"
                       TextColor="{AppThemeBinding Light='#666', Dark='#AAA'}" />
            </VerticalStackLayout>

            <!-- Plant List -->
            <CollectionView Grid.Row="1"
                            ItemsSource="{Binding Plants}"
                            AutomationId="PlantList"
                            SelectionMode="Single"
                            SelectionChanged="OnPlantSelected"
                            EmptyView="No plants yet. Tap + to add one or chat with the AI assistant! 🌿">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Plant">
                        <Border Padding="12" Margin="0,4"
                                Stroke="{AppThemeBinding Light='#C8E6C9', Dark='#2E7D32'}"
                                StrokeThickness="1"
                                BackgroundColor="{AppThemeBinding Light='#F1F8E9', Dark='#1B3A1B'}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10" />
                            </Border.StrokeShape>
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                <Label Text="🪴" FontSize="32" VerticalOptions="Center" />
                                <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                    <Label Text="{Binding Nickname}"
                                           FontSize="16"
                                           FontAttributes="Bold" />
                                    <Label Text="{Binding Location, StringFormat='📍 {0}'}"
                                           FontSize="13"
                                           TextColor="{AppThemeBinding Light='#555', Dark='#BBB'}" />
                                </VerticalStackLayout>
                                <Label Grid.Column="2" Text="›" FontSize="24"
                                       VerticalOptions="Center"
                                       TextColor="{AppThemeBinding Light='#999', Dark='#666'}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Bottom buttons -->
            <Grid Grid.Row="2" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <Button Text="💬 Chat with Garden Assistant"
                        Clicked="OnOpenChatClicked"
                        AutomationId="OpenChatButton"
                        HorizontalOptions="Fill" />
                <Button Grid.Column="1" Text="➕"
                        Clicked="OnAddPlantClicked"
                        AutomationId="AddPlantButton"
                        BackgroundColor="#2E7D32"
                        TextColor="White"
                        FontSize="20"
                        WidthRequest="50"
                        CornerRadius="25" />
            </Grid>
        </Grid>

        <!-- Chat Popup Overlay -->
        <Grid x:Name="ChatOverlay"
              IsVisible="False"
              AutomationId="ChatOverlay"
              BackgroundColor="#80000000">

            <!-- Dismiss tapping on backdrop -->
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnChatBackdropTapped" />
            </Grid.GestureRecognizers>

            <!-- Chat Panel -->
            <Border x:Name="ChatPanel"
                    VerticalOptions="End"
                    HorizontalOptions="Fill"
                    HeightRequest="450"
                    Margin="12,0,12,12"
                    Padding="0"
                    Stroke="{AppThemeBinding Light='#C0C0C0', Dark='#555'}"
                    StrokeThickness="1"
                    BackgroundColor="{AppThemeBinding Light='White', Dark='#1E1E1E'}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16,16,8,8" />
                </Border.StrokeShape>

                <Grid RowDefinitions="Auto,*,Auto,Auto" Padding="12" RowSpacing="8">

                    <!-- Header with close button -->
                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                        <Label Text="🌱 Garden Assistant"
                               FontSize="18"
                               FontAttributes="Bold"
                               VerticalOptions="Center" />
                        <Button Grid.Column="1"
                                Text="✕"
                                FontSize="16"
                                BackgroundColor="Transparent"
                                TextColor="{AppThemeBinding Light='#333', Dark='#CCC'}"
                                Clicked="OnCloseChatClicked"
                                AutomationId="CloseChatButton"
                                Padding="8,4"
                                MinimumWidthRequest="40" />
                    </Grid>

                    <!-- Messages -->
                    <CollectionView Grid.Row="1"
                                    ItemsSource="{Binding ChatViewModel.Messages}"
                                    AutomationId="ChatMessages"
                                    VerticalOptions="Fill">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="vm:ChatMessage">
                                <VerticalStackLayout Padding="4,2">
                                    <Label Text="{Binding Role, StringFormat='[{0}]'}"
                                           FontSize="10"
                                           FontAttributes="Bold"
                                           TextColor="Gray" />
                                    <Label Text="{Binding Content}"
                                           FontSize="14"
                                           Margin="0,0,0,6" />
                                </VerticalStackLayout>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <!-- Busy indicator -->
                    <ActivityIndicator Grid.Row="2"
                                       IsRunning="{Binding ChatViewModel.IsBusy}"
                                       IsVisible="{Binding ChatViewModel.IsBusy}" />

                    <!-- Input Area -->
                    <Grid Grid.Row="3" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <Entry Grid.Column="0"
                               Placeholder="Tell me about your plants..."
                               Text="{Binding ChatViewModel.UserInput}"
                               ReturnCommand="{Binding ChatViewModel.SendCommand}"
                               AutomationId="ChatInput" />
                        <Button Grid.Column="1"
                                Text="Send"
                                Command="{Binding ChatViewModel.SendCommand}"
                                AutomationId="SendButton" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>

</ContentPage>
