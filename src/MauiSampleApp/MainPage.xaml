<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:MauiSampleApp.Controls"
             xmlns:converters="clr-namespace:MauiSampleApp.Converters"
             xmlns:vm="clr-namespace:MauiSampleApp.ViewModels"
             x:Class="MauiSampleApp.MainPage"
             Title="Weather App">

    <ContentPage.Resources>
        <converters:StringToBoolConverter x:Key="StringToBoolConverter" />
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*,Auto" Padding="16" RowSpacing="12">

        <!-- Search Section -->
        <VerticalStackLayout Grid.Row="0" Spacing="8">
            <Label Text="Weather Forecast" FontSize="24" FontAttributes="Bold" />
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <Entry x:Name="LocationEntry"
                       Grid.Column="0"
                       Placeholder="Enter city or location..."
                       Text="{Binding LocationQuery}"
                       ReturnCommand="{Binding SearchCommand}"
                       AutomationId="LocationEntry" />
                <Button Grid.Column="1"
                        Text="Search"
                        Command="{Binding SearchCommand}"
                        AutomationId="SearchButton" />
            </Grid>
            <ActivityIndicator IsRunning="{Binding IsLoading}" IsVisible="{Binding IsLoading}" />
            <Label Text="{Binding StatusMessage}"
                   IsVisible="{Binding StatusMessage, Converter={StaticResource StringToBoolConverter}}"
                   TextColor="OrangeRed" />
        </VerticalStackLayout>

        <!-- Weather Results -->
        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding WeatherItems}"
                        AutomationId="WeatherResults">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Horizontal" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <controls:WeatherControl
                        Date="{Binding Date}"
                        Emoji="{Binding Emoji}"
                        Temperature="{Binding Temperature}"
                        Description="{Binding Description}"
                        WidthRequest="110" />
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Open Chat Button -->
        <Button Grid.Row="2"
                Text="💬 Open AI Chat"
                Clicked="OnOpenChatClicked"
                AutomationId="OpenChatButton"
                HorizontalOptions="Fill" />
    </Grid>

</ContentPage>
