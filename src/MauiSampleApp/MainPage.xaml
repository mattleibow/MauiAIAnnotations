<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MauiSampleApp.ViewModels"
             xmlns:models="clr-namespace:MauiSampleApp.Core.Models;assembly=MauiSampleApp.Core"
             x:Class="MauiSampleApp.MainPage"
             Title="My Garden"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light={StaticResource PageBg}, Dark={StaticResource PageBgDark}}"
             Shell.BackgroundColor="{StaticResource AccentGreen}">

    <Grid>
        <!-- Main Content -->
        <Grid RowDefinitions="Auto,*,Auto" RowSpacing="0">

            <!-- Hero Header -->
            <Border Grid.Row="0"
                    BackgroundColor="{StaticResource AccentGreen}"
                    Padding="24,20,24,24"
                    StrokeThickness="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="0,0,24,24" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="6">
                    <Label Text="My Garden"
                           FontSize="32"
                           FontAttributes="Bold"
                           TextColor="White"
                           AutomationId="PageTitle" />
                    <Label Text="Your plants, your way. Tap a plant or chat with your AI assistant."
                           FontSize="14"
                           TextColor="#D4E8D4" />
                </VerticalStackLayout>
            </Border>

            <!-- Plant List -->
            <CollectionView Grid.Row="1"
                            ItemsSource="{Binding Plants}"
                            AutomationId="PlantList"
                            SelectionMode="Single"
                            SelectionChanged="OnPlantSelected"
                            Margin="16,16,16,0">
                <CollectionView.EmptyView>
                    <VerticalStackLayout Spacing="12" VerticalOptions="Center" HorizontalOptions="Center" Padding="40">
                        <Label Text="&#x1F331;" FontSize="56" HorizontalOptions="Center" />
                        <Label Text="No plants yet"
                               FontSize="20" FontAttributes="Bold"
                               HorizontalOptions="Center"
                               TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
                        <Label Text="Tap + to add your first plant, or ask the AI assistant!"
                               FontSize="14"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center"
                               TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Plant">
                        <Border Padding="16"
                                Margin="0,0,0,12"
                                BackgroundColor="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}"
                                Stroke="{AppThemeBinding Light={StaticResource CardBorder}, Dark={StaticResource CardBorderDark}}"
                                StrokeThickness="1">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="16" />
                            </Border.StrokeShape>
                            <Grid ColumnDefinitions="52,*,Auto" ColumnSpacing="14">
                                <!-- Plant avatar -->
                                <Border WidthRequest="52" HeightRequest="52"
                                        BackgroundColor="{StaticResource BadgeOutdoor}"
                                        StrokeThickness="0"
                                        VerticalOptions="Center">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="14" />
                                    </Border.StrokeShape>
                                    <Label Text="&#x1FAB4;" FontSize="26" HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>
                                <!-- Info -->
                                <VerticalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                                    <Label Text="{Binding Nickname}"
                                           FontSize="17"
                                           FontAttributes="Bold"
                                           TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
                                    <HorizontalStackLayout Spacing="6">
                                        <Label Text="{Binding Location}"
                                               FontSize="13"
                                               TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}" />
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>
                                <!-- Chevron -->
                                <Label Grid.Column="2" Text="&#x203A;" FontSize="28"
                                       VerticalOptions="Center"
                                       TextColor="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Bottom Bar -->
            <Grid Grid.Row="2" ColumnDefinitions="*,Auto"
                  Padding="16,12,16,16" ColumnSpacing="12"
                  BackgroundColor="{AppThemeBinding Light={StaticResource PageBg}, Dark={StaticResource PageBgDark}}">
                <Button Text="&#x1F4AC;  Chat with Assistant"
                        Clicked="OnOpenChatClicked"
                        AutomationId="OpenChatButton"
                        BackgroundColor="{StaticResource AccentGreen}"
                        TextColor="White"
                        FontSize="15"
                        FontAttributes="Bold"
                        CornerRadius="14"
                        HeightRequest="50"
                        HorizontalOptions="Fill" />
                <Button Grid.Column="1"
                        Text="+"
                        Clicked="OnAddPlantClicked"
                        AutomationId="AddPlantButton"
                        BackgroundColor="{StaticResource AccentOchre}"
                        TextColor="White"
                        FontSize="24"
                        FontAttributes="Bold"
                        WidthRequest="50"
                        HeightRequest="50"
                        CornerRadius="14" />
            </Grid>
        </Grid>

        <!-- Chat Popup Overlay -->
        <Grid x:Name="ChatOverlay"
              IsVisible="False"
              AutomationId="ChatOverlay"
              BackgroundColor="#66000000">

            <Grid.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnChatBackdropTapped" />
            </Grid.GestureRecognizers>

            <Border VerticalOptions="End"
                    HorizontalOptions="Fill"
                    HeightRequest="500"
                    Margin="12,0,12,12"
                    Padding="0"
                    InputTransparent="False"
                    Stroke="{AppThemeBinding Light={StaticResource CardBorder}, Dark={StaticResource CardBorderDark}}"
                    StrokeThickness="1"
                    BackgroundColor="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20,20,12,12" />
                </Border.StrokeShape>

                <Grid RowDefinitions="Auto,*,Auto,Auto" RowSpacing="0">

                    <!-- Chat Header -->
                    <Border Grid.Row="0"
                            BackgroundColor="{StaticResource AccentGreen}"
                            Padding="16,14"
                            StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="20,20,0,0" />
                        </Border.StrokeShape>
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="&#x1F33F; Garden Assistant"
                                   FontSize="17"
                                   FontAttributes="Bold"
                                   TextColor="White"
                                   VerticalOptions="Center" />
                            <Button Grid.Column="1"
                                    Text="&#x2715;"
                                    FontSize="16"
                                    BackgroundColor="Transparent"
                                    TextColor="#D4E8D4"
                                    Clicked="OnCloseChatClicked"
                                    AutomationId="CloseChatButton"
                                    Padding="8,4"
                                    MinimumWidthRequest="40" />
                        </Grid>
                    </Border>

                    <!-- Messages -->
                    <CollectionView Grid.Row="1"
                                    ItemsSource="{Binding ChatViewModel.Messages}"
                                    AutomationId="ChatMessages"
                                    Margin="12,8,12,0">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="vm:ChatMessage">
                                <Grid Padding="0,4">
                                    <Border Padding="12,10"
                                            MaximumWidthRequest="340"
                                            HorizontalOptions="Start"
                                            BackgroundColor="{AppThemeBinding Light=#F0EBE3, Dark=#33302A}"
                                            StrokeThickness="0">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="16,16,16,4" />
                                        </Border.StrokeShape>
                                        <VerticalStackLayout Spacing="2">
                                            <Label Text="{Binding Role}"
                                                   FontSize="11"
                                                   FontAttributes="Bold"
                                                   TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}" />
                                            <Label Text="{Binding Content}"
                                                   FontSize="14"
                                                   TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
                                        </VerticalStackLayout>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <!-- Busy indicator -->
                    <ActivityIndicator Grid.Row="2"
                                       IsRunning="{Binding ChatViewModel.IsBusy}"
                                       IsVisible="{Binding ChatViewModel.IsBusy}"
                                       Color="{StaticResource AccentGreen}"
                                       Margin="0,6" />

                    <!-- Input Area -->
                    <Border Grid.Row="3" Margin="12,8,12,12" Padding="6"
                            BackgroundColor="{AppThemeBinding Light=#F0EBE3, Dark=#33302A}"
                            StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14" />
                        </Border.StrokeShape>
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                            <Entry Placeholder="Ask about your plants..."
                                   Text="{Binding ChatViewModel.UserInput}"
                                   ReturnCommand="{Binding ChatViewModel.SendCommand}"
                                   AutomationId="ChatInput"
                                   FontSize="14"
                                   BackgroundColor="Transparent" />
                            <Button Grid.Column="1"
                                    Text="&#x27A4;"
                                    Command="{Binding ChatViewModel.SendCommand}"
                                    AutomationId="SendButton"
                                    BackgroundColor="{StaticResource AccentGreen}"
                                    TextColor="White"
                                    FontSize="16"
                                    WidthRequest="42"
                                    HeightRequest="42"
                                    CornerRadius="12"
                                    Padding="0" />
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>

</ContentPage>
