<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:MauiSampleApp.Core.Models;assembly=MauiSampleApp.Core"
             x:Class="MauiSampleApp.Controls.WeatherControl"
             x:DataType="models:WeatherDay">

    <Border Padding="12"
            StrokeShape="RoundRectangle 8"
            Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#404040}"
            BackgroundColor="{AppThemeBinding Light=#F8F8F8, Dark=#2A2A2A}"
            Margin="4">
        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
            <Label Text="{Binding Emoji}"
                   FontSize="32"
                   VerticalOptions="Center"
                   Grid.Column="0" />

            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                <Label Text="{Binding Date, StringFormat='{0:ddd, MMM dd}'}"
                       FontAttributes="Bold"
                       FontSize="16" />
                <Label Text="{Binding Description}"
                       FontSize="13"
                       TextColor="{AppThemeBinding Light=#666666, Dark=#AAAAAA}" />
            </VerticalStackLayout>

            <Label Grid.Column="2"
                   VerticalOptions="Center"
                   FontSize="22"
                   FontAttributes="Bold">
                <Label.Text>
                    <Binding Path="Temperature" StringFormat="{}{0:F0}°C" />
                </Label.Text>
            </Label>
        </Grid>
    </Border>

</ContentView>
