<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiSampleApp.Controls.WeatherControl">
    <Border Stroke="{AppThemeBinding Light='#E0E0E0', Dark='#404040'}"
            StrokeThickness="1"
            BackgroundColor="{AppThemeBinding Light='White', Dark='#2D2D2D'}"
            Margin="4"
            Padding="12">
        <Border.StrokeShape>
            <RoundRectangle CornerRadius="8" />
        </Border.StrokeShape>
        <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
            <Label Text="{Binding Date, Source={RelativeSource AncestorType={x:Type ContentView}}}"
                   FontSize="12"
                   HorizontalOptions="Center"
                   TextColor="{AppThemeBinding Light='#666', Dark='#AAA'}" />
            <Label Text="{Binding Emoji, Source={RelativeSource AncestorType={x:Type ContentView}}}"
                   FontSize="32"
                   HorizontalOptions="Center" />
            <Label Text="{Binding Temperature, Source={RelativeSource AncestorType={x:Type ContentView}}, StringFormat='{0:F0}°C'}"
                   FontSize="18"
                   FontAttributes="Bold"
                   HorizontalOptions="Center" />
            <Label Text="{Binding Description, Source={RelativeSource AncestorType={x:Type ContentView}}}"
                   FontSize="11"
                   HorizontalOptions="Center"
                   TextColor="{AppThemeBinding Light='#555', Dark='#BBB'}" />
        </VerticalStackLayout>
    </Border>
</ContentView>
