<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MauiSampleApp.ViewModels"
             x:Class="MauiSampleApp.ChatPage"
             Title="AI Chat">

    <Grid RowDefinitions="*,Auto,Auto" Padding="16" RowSpacing="8">

        <!-- Messages -->
        <CollectionView Grid.Row="0"
                        ItemsSource="{Binding Messages}"
                        AutomationId="ChatMessages"
                        VerticalOptions="Fill">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="vm:ChatMessage">
                    <VerticalStackLayout Padding="4,2">
                        <Label Text="{Binding Role, StringFormat='[{0}]'}"
                               FontSize="10"
                               FontAttributes="Bold"
                               TextColor="Gray" />
                        <Label Text="{Binding Content}"
                               FontSize="14"
                               Margin="0,0,0,6" />
                    </VerticalStackLayout>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Busy indicator -->
        <ActivityIndicator Grid.Row="1"
                           IsRunning="{Binding IsBusy}"
                           IsVisible="{Binding IsBusy}" />

        <!-- Input Area -->
        <Grid Grid.Row="2" ColumnDefinitions="*,Auto" ColumnSpacing="8">
            <Entry Grid.Column="0"
                   Placeholder="Ask about weather..."
                   Text="{Binding UserInput}"
                   ReturnCommand="{Binding SendCommand}"
                   AutomationId="ChatInput" />
            <Button Grid.Column="1"
                    Text="Send"
                    Command="{Binding SendCommand}"
                    AutomationId="SendButton" />
        </Grid>
    </Grid>

</ContentPage>
