<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                    xmlns:chat="clr-namespace:Microsoft.Extensions.AI.Maui.Chat"
                    x:Class="Microsoft.Extensions.AI.Maui.Themes.ChatTheme">

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- Design Tokens — Colors                                        -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <Color x:Key="ExtensionsAI.User.Background">#5B8C5A</Color>
    <Color x:Key="ExtensionsAI.User.TextColor">White</Color>
    <Color x:Key="ExtensionsAI.Assistant.Background">#F0EBE3</Color>
    <Color x:Key="ExtensionsAI.Assistant.TextColor">#2C2416</Color>
    <Color x:Key="ExtensionsAI.FunctionCall.Background">#E8E0D4</Color>
    <Color x:Key="ExtensionsAI.FunctionCall.TextColor">#7A7062</Color>
    <Color x:Key="ExtensionsAI.FunctionResult.Background">#EDF6EC</Color>
    <Color x:Key="ExtensionsAI.FunctionResult.TextColor">#7A7062</Color>
    <Color x:Key="ExtensionsAI.Error.Background">#FDE8E8</Color>
    <Color x:Key="ExtensionsAI.Error.TextColor">#C75050</Color>
    <Color x:Key="ExtensionsAI.Default.TextColor">#7A7062</Color>
    <Color x:Key="ExtensionsAI.Approval.Background">#FFFBF0</Color>
    <Color x:Key="ExtensionsAI.Approval.Border">#E8D9B5</Color>
    <Color x:Key="ExtensionsAI.Approval.HeaderColor">#8B7340</Color>
    <Color x:Key="ExtensionsAI.Button.Approve">#5B8C5A</Color>
    <Color x:Key="ExtensionsAI.Button.Reject">#C75050</Color>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- ControlTemplate: ChatMessageView (User + Assistant)           -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <ControlTemplate x:Key="ExtensionsAI.ChatMessageTemplate">
        <Grid x:Name="PART_Root" Padding="0,4">
            <VisualStateManager.VisualStateGroups>
                <VisualStateGroup x:Name="RoleStates">
                    <VisualState x:Name="User">
                        <VisualState.Setters>
                            <Setter TargetName="MessageBorder" Property="Border.BackgroundColor"
                                    Value="{DynamicResource ExtensionsAI.User.Background}" />
                            <Setter TargetName="MessageBorder" Property="Border.HorizontalOptions"
                                    Value="End" />
                            <Setter TargetName="MessageLabel" Property="Label.TextColor"
                                    Value="{DynamicResource ExtensionsAI.User.TextColor}" />
                            <Setter TargetName="MessageShape" Property="RoundRectangle.CornerRadius"
                                    Value="16,16,4,16" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="Assistant">
                        <VisualState.Setters>
                            <Setter TargetName="MessageBorder" Property="Border.BackgroundColor"
                                    Value="{DynamicResource ExtensionsAI.Assistant.Background}" />
                            <Setter TargetName="MessageBorder" Property="Border.HorizontalOptions"
                                    Value="Start" />
                            <Setter TargetName="MessageLabel" Property="Label.TextColor"
                                    Value="{DynamicResource ExtensionsAI.Assistant.TextColor}" />
                            <Setter TargetName="MessageShape" Property="RoundRectangle.CornerRadius"
                                    Value="16,16,16,4" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateManager.VisualStateGroups>

            <Border x:Name="MessageBorder" Padding="12,10" MaximumWidthRequest="340"
                    HorizontalOptions="Start"
                    BackgroundColor="{DynamicResource ExtensionsAI.Assistant.Background}"
                    StrokeThickness="0">
                <Border.StrokeShape>
                    <RoundRectangle x:Name="MessageShape" CornerRadius="16,16,16,4" />
                </Border.StrokeShape>
                <Label x:Name="MessageLabel"
                       Text="{TemplateBinding Text}" FontSize="14"
                       TextColor="{DynamicResource ExtensionsAI.Assistant.TextColor}" />
            </Border>
        </Grid>
    </ControlTemplate>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- ControlTemplate: FunctionCallMessageView                      -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <ControlTemplate x:Key="ExtensionsAI.FunctionCallTemplate">
        <Grid Padding="0,2">
            <Border Padding="10,6" HorizontalOptions="Start"
                    BackgroundColor="{DynamicResource ExtensionsAI.FunctionCall.Background}"
                    StrokeThickness="0" Opacity="0.85">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10" />
                </Border.StrokeShape>
                <HorizontalStackLayout Spacing="6">
                    <Label Text="⚙️" FontSize="12" VerticalOptions="Center" />
                    <Label Text="{TemplateBinding FunctionName, StringFormat='Calling {0}...'}"
                           FontSize="12" FontAttributes="Italic"
                           TextColor="{DynamicResource ExtensionsAI.FunctionCall.TextColor}" />
                </HorizontalStackLayout>
            </Border>
        </Grid>
    </ControlTemplate>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- ControlTemplate: FunctionResultMessageView                    -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <ControlTemplate x:Key="ExtensionsAI.FunctionResultTemplate">
        <Grid Padding="0,2">
            <Border Padding="10,6" HorizontalOptions="Start"
                    BackgroundColor="{DynamicResource ExtensionsAI.FunctionResult.Background}"
                    StrokeThickness="0" Opacity="0.85">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10" />
                </Border.StrokeShape>
                <Label Text="{TemplateBinding ResultText}" FontSize="11"
                       LineBreakMode="WordWrap" MaximumWidthRequest="300"
                       TextColor="{DynamicResource ExtensionsAI.FunctionResult.TextColor}" />
            </Border>
        </Grid>
    </ControlTemplate>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- ControlTemplate: ErrorMessageView                             -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <ControlTemplate x:Key="ExtensionsAI.ErrorTemplate">
        <Grid Padding="0,4">
            <Border Padding="12,10" MaximumWidthRequest="340" HorizontalOptions="Start"
                    BackgroundColor="{DynamicResource ExtensionsAI.Error.Background}" StrokeThickness="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12" />
                </Border.StrokeShape>
                <Label Text="{TemplateBinding ErrorMessageText}" FontSize="14"
                       TextColor="{DynamicResource ExtensionsAI.Error.TextColor}" />
            </Border>
        </Grid>
    </ControlTemplate>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- ControlTemplate: DefaultMessageView                           -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <ControlTemplate x:Key="ExtensionsAI.DefaultTemplate">
        <Grid>
            <Label Text="{TemplateBinding DisplayText}" FontSize="13" Padding="4"
                   TextColor="{DynamicResource ExtensionsAI.Default.TextColor}" />
        </Grid>
    </ControlTemplate>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- ControlTemplate: ToolApprovalView                              -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <ControlTemplate x:Key="ExtensionsAI.ToolApprovalTemplate">
        <Border Padding="14,12" Margin="0,6" HorizontalOptions="Fill"
                BackgroundColor="{DynamicResource ExtensionsAI.Approval.Background}"
                Stroke="{DynamicResource ExtensionsAI.Approval.Border}"
                StrokeThickness="1">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="14" />
            </Border.StrokeShape>

            <Grid x:Name="PART_Root" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="10">
                <VisualStateManager.VisualStateGroups>
                    <VisualStateGroup x:Name="ApprovalStates">
                        <VisualState x:Name="Pending">
                            <VisualState.Setters>
                                <Setter TargetName="ButtonsRow" Property="IsVisible" Value="True" />
                                <Setter TargetName="ResolutionLabel" Property="IsVisible" Value="False" />
                            </VisualState.Setters>
                        </VisualState>
                        <VisualState x:Name="Resolved">
                            <VisualState.Setters>
                                <Setter TargetName="ButtonsRow" Property="IsVisible" Value="False" />
                                <Setter TargetName="ResolutionLabel" Property="IsVisible" Value="True" />
                            </VisualState.Setters>
                        </VisualState>
                    </VisualStateGroup>
                </VisualStateManager.VisualStateGroups>

                <Label Text="⚠️ Approval Required"
                       FontSize="15"
                       FontAttributes="Bold"
                       TextColor="{DynamicResource ExtensionsAI.Approval.HeaderColor}" />

                <Label Grid.Row="1"
                       Text="{TemplateBinding ToolName}"
                       FontSize="14"
                       FontAttributes="Bold"
                       TextColor="{DynamicResource ExtensionsAI.Assistant.TextColor}" />

                <ContentPresenter Grid.Row="2" />

                <Grid x:Name="ButtonsRow"
                      Grid.Row="3"
                      ColumnDefinitions="*,*"
                      ColumnSpacing="10">
                    <Button x:Name="PART_ApproveButton"
                            Text="Approve"
                            AutomationId="ApproveToolButton"
                            Command="{TemplateBinding ApproveCommand}"
                            BackgroundColor="{DynamicResource ExtensionsAI.Button.Approve}"
                            TextColor="White"
                            FontSize="14"
                            FontAttributes="Bold"
                            CornerRadius="10"
                            HeightRequest="40" />
                    <Button x:Name="PART_RejectButton"
                            Grid.Column="1"
                            Text="Reject"
                            AutomationId="RejectToolButton"
                            Command="{TemplateBinding RejectCommand}"
                            BackgroundColor="{DynamicResource ExtensionsAI.Button.Reject}"
                            TextColor="White"
                            FontSize="14"
                            FontAttributes="Bold"
                            CornerRadius="10"
                            HeightRequest="40" />
                </Grid>

                <Label x:Name="ResolutionLabel"
                       Grid.Row="3"
                       IsVisible="False"
                       Text="{TemplateBinding ResolutionText}"
                       FontSize="14"
                       FontAttributes="Bold"
                       TextColor="{DynamicResource ExtensionsAI.Approval.HeaderColor}"
                       HorizontalOptions="Center"
                       Padding="8,6" />
            </Grid>
        </Border>
    </ControlTemplate>

    <Style x:Key="ExtensionsAI.ToolApproval.ArgsStackStyle" TargetType="VerticalStackLayout">
        <Setter Property="Spacing" Value="4" />
    </Style>

    <Style x:Key="ExtensionsAI.ToolApproval.ArgsRowStyle" TargetType="HorizontalStackLayout">
        <Setter Property="Spacing" Value="6" />
    </Style>

    <Style x:Key="ExtensionsAI.ToolApproval.EmptyArgsLabelStyle" TargetType="Label">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="TextColor" Value="{DynamicResource ExtensionsAI.Default.TextColor}" />
    </Style>

    <Style x:Key="ExtensionsAI.ToolApproval.ArgNameLabelStyle" TargetType="Label">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{DynamicResource ExtensionsAI.FunctionCall.TextColor}" />
    </Style>

    <Style x:Key="ExtensionsAI.ToolApproval.ArgValueLabelStyle" TargetType="Label">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="TextColor" Value="{DynamicResource ExtensionsAI.Assistant.TextColor}" />
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- Implicit Styles — wire ControlTemplate via DynamicResource     -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <Style TargetType="chat:ChatMessageView">
        <Setter Property="ControlTemplate" Value="{DynamicResource ExtensionsAI.ChatMessageTemplate}" />
    </Style>

    <Style TargetType="chat:FunctionCallMessageView">
        <Setter Property="ControlTemplate" Value="{DynamicResource ExtensionsAI.FunctionCallTemplate}" />
    </Style>

    <Style TargetType="chat:FunctionResultMessageView">
        <Setter Property="ControlTemplate" Value="{DynamicResource ExtensionsAI.FunctionResultTemplate}" />
    </Style>

    <Style TargetType="chat:ErrorMessageView">
        <Setter Property="ControlTemplate" Value="{DynamicResource ExtensionsAI.ErrorTemplate}" />
    </Style>

    <Style TargetType="chat:DefaultMessageView">
        <Setter Property="ControlTemplate" Value="{DynamicResource ExtensionsAI.DefaultTemplate}" />
    </Style>

    <Style TargetType="chat:ToolApprovalView">
        <Setter Property="ControlTemplate" Value="{DynamicResource ExtensionsAI.ToolApprovalTemplate}" />
    </Style>

</ResourceDictionary>
