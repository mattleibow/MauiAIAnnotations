<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="MauiSampleApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:MauiSampleApp"
    xmlns:pages="clr-namespace:MauiSampleApp.Pages"
    Title="Garden Helper"
    Shell.FlyoutBehavior="Disabled"
    Shell.NavBarHasShadow="True"
    Shell.BackgroundColor="{StaticResource AccentGreen}"
    Shell.ForegroundColor="White"
    Shell.TitleColor="White"
    Shell.UnselectedColor="#B5D8B2"
    Shell.TabBarBackgroundColor="{StaticResource AccentGreen}"
    Shell.TabBarForegroundColor="White"
    Shell.TabBarUnselectedColor="#B5D8B2"
    Shell.TabBarTitleColor="White">

    <TabBar>
        <ShellContent
            Title="My Garden"
            Icon="{FontImageSource FontFamily='OpenSansRegular', Glyph='&#x1FAB4;', Color=White}"
            ContentTemplate="{DataTemplate pages:HomePage}"
            Route="HomePage" />

        <ShellContent
            Title="AI Chat"
            Icon="{FontImageSource FontFamily='OpenSansRegular', Glyph='&#x1F4AC;', Color=White}"
            ContentTemplate="{DataTemplate pages:ChatPage}"
            Route="ChatPage" />
    </TabBar>

</Shell>
