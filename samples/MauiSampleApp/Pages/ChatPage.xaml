<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:maui="clr-namespace:Microsoft.Extensions.AI.Maui.Controls;assembly=Microsoft.Extensions.AI.Maui"
             xmlns:mauiChat="clr-namespace:Microsoft.Extensions.AI.Maui.Chat;assembly=Microsoft.Extensions.AI.Maui"
             xmlns:local="clr-namespace:MauiSampleApp.Chat"
             x:Class="MauiSampleApp.Pages.ChatPage"
             x:Name="ThisPage"
             Title="AI Chat"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light={StaticResource PageBg}, Dark={StaticResource PageBgDark}}">

    <Grid RowDefinitions="Auto,*" RowSpacing="0">
        <!-- Chat Header -->
        <Border Grid.Row="0"
                BackgroundColor="#5B8C5A"
                Padding="16,14"
                StrokeThickness="0">
            <Grid ColumnDefinitions="*,Auto">
                <Label Text="&#x1F33F; AI Chat Assistant"
                       FontSize="20" FontAttributes="Bold"
                       TextColor="White" VerticalOptions="Center" />
                <Button Grid.Column="1" Text="&#x1F5D1;"
                        FontSize="16"
                        AutomationId="ClearChatButton"
                        BackgroundColor="Transparent" TextColor="#D4E8D4"
                        Clicked="OnClearChatClicked"
                        Padding="8,4" MinimumWidthRequest="44"
                        ToolTipProperties.Text="Clear chat" />
            </Grid>
        </Border>

        <!-- Chat Panel -->
        <maui:ChatPanelControl Grid.Row="1"
                               Session="{Binding Source={x:Reference ThisPage}, Path=ChatSession}">
            <maui:ChatPanelControl.ContentTemplates>
                <mauiChat:TextContentTemplate Role="User" />
                <mauiChat:TextContentTemplate Role="Assistant" />
                <mauiChat:FunctionCallTemplate />
                <mauiChat:ToolApprovalTemplate ToolName="add_plant" ViewType="{x:Type local:PlantApprovalView}" />
                <mauiChat:ToolApprovalTemplate ToolName="log_batch_care_events" ViewType="{x:Type local:BatchCareApprovalView}" />
                <mauiChat:ToolApprovalTemplate />
                <local:PlantResultTemplate ToolName="add_plant" ViewType="{x:Type local:PlantResultView}" />
                <local:PlantResultTemplate ToolName="get_plant" ViewType="{x:Type local:PlantResultView}" />
                <local:PlantResultTemplate ToolName="get_plants" ViewType="{x:Type local:PlantResultView}" />
                <mauiChat:FunctionResultTemplate />
                <mauiChat:ErrorContentTemplate />
                <mauiChat:DefaultContentTemplate />
            </maui:ChatPanelControl.ContentTemplates>
        </maui:ChatPanelControl>
    </Grid>

</ContentPage>
