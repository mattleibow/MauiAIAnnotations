<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MauiSampleApp.ViewModels"
             xmlns:models="clr-namespace:MauiSampleApp.Core.Models;assembly=MauiSampleApp.Core"
             xmlns:maui="clr-namespace:MauiAIAnnotations.Maui.Controls;assembly=MauiAIAnnotations.Maui"
             xmlns:mauiChat="clr-namespace:MauiAIAnnotations.Maui.Chat;assembly=MauiAIAnnotations.Maui"
             xmlns:local="clr-namespace:MauiSampleApp.Chat"
             x:Class="MauiSampleApp.Pages.HomePage"
             Title="My Garden"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light={StaticResource PageBg}, Dark={StaticResource PageBgDark}}"
             Shell.BackgroundColor="{StaticResource AccentGreen}">

    <Grid>
        <!-- Main Content -->
        <Grid RowDefinitions="Auto,*" RowSpacing="0">

            <!-- Hero Header -->
            <Border Grid.Row="0"
                    BackgroundColor="{StaticResource AccentGreen}"
                    Padding="24,20,24,24"
                    StrokeThickness="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="0,0,24,24" />
                </Border.StrokeShape>
                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="My Garden"
                               FontSize="32"
                               FontAttributes="Bold"
                               TextColor="White"
                               AutomationId="PageTitle" />
                        <Label Text="Your plants, your way. Tap a plant or chat with your AI assistant."
                               FontSize="14"
                               TextColor="#D4E8D4" />
                    </VerticalStackLayout>
                    <Button Grid.Column="1"
                            Text="+"
                            Clicked="OnAddPlantClicked"
                            AutomationId="AddPlantButton"
                            BackgroundColor="{StaticResource AccentOchre}"
                            TextColor="White"
                            FontSize="24"
                            FontAttributes="Bold"
                            WidthRequest="46"
                            HeightRequest="46"
                            CornerRadius="23"
                            VerticalOptions="Start"
                            Padding="0" />
                </Grid>
            </Border>

            <!-- Plant List -->
            <CollectionView Grid.Row="1"
                            ItemsSource="{Binding Plants}"
                            AutomationId="PlantList"
                            SelectionMode="Single"
                            SelectionChanged="OnPlantSelected"
                            Margin="16,16,16,0">
                <CollectionView.EmptyView>
                    <VerticalStackLayout Spacing="12" VerticalOptions="Center" HorizontalOptions="Center" Padding="40">
                        <Label Text="&#x1F331;" FontSize="56" HorizontalOptions="Center" />
                        <Label Text="No plants yet"
                               FontSize="20" FontAttributes="Bold"
                               HorizontalOptions="Center"
                               TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
                        <Label Text="Tap + to add your first plant, or ask the AI assistant!"
                               FontSize="14"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center"
                               TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Plant">
                        <Border Padding="16"
                                Margin="0,0,0,12"
                                BackgroundColor="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}"
                                Stroke="{AppThemeBinding Light={StaticResource CardBorder}, Dark={StaticResource CardBorderDark}}"
                                StrokeThickness="1">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="16" />
                            </Border.StrokeShape>
                            <Grid ColumnDefinitions="52,*,Auto" ColumnSpacing="14">
                                <!-- Plant avatar -->
                                <Border WidthRequest="52" HeightRequest="52"
                                        BackgroundColor="{StaticResource BadgeOutdoor}"
                                        StrokeThickness="0"
                                        VerticalOptions="Center">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="14" />
                                    </Border.StrokeShape>
                                    <Label Text="&#x1FAB4;" FontSize="26" HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>
                                <!-- Info -->
                                <VerticalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                                    <Label Text="{Binding Nickname}"
                                           FontSize="17"
                                           FontAttributes="Bold"
                                           TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
                                    <HorizontalStackLayout Spacing="6">
                                        <Label Text="{Binding Location}"
                                               FontSize="13"
                                               TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}" />
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>
                                <!-- Chevron -->
                                <Label Grid.Column="2" Text="&#x203A;" FontSize="28"
                                       VerticalOptions="Center"
                                       TextColor="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </Grid>

        <!-- Reusable Chat Overlay -->
        <maui:ChatOverlayControl ChatVM="{Binding ChatViewModel}"
                                 ChatClosed="OnChatClosed">
            <maui:ChatOverlayControl.ContentTemplates>
                <mauiChat:TextContentMapping Role="User" ViewType="{x:Type mauiChat:UserTextView}" />
                <mauiChat:TextContentMapping Role="Assistant" ViewType="{x:Type mauiChat:AssistantTextView}" />
                <mauiChat:FunctionCallMapping ViewType="{x:Type mauiChat:FunctionCallView}" />
                <mauiChat:ToolApprovalMapping ToolName="add_plant" InnerViewType="{x:Type local:PlantApprovalView}" ViewType="{x:Type mauiChat:ToolApprovalView}" />
                <mauiChat:ToolApprovalMapping ToolName="log_batch_care_events" InnerViewType="{x:Type local:BatchCareApprovalView}" ViewType="{x:Type mauiChat:ToolApprovalView}" />
                <mauiChat:ToolApprovalMapping ViewType="{x:Type mauiChat:ToolApprovalView}" />
                <local:PlantResultMapping ViewType="{x:Type local:PlantResultView}" />
                <mauiChat:FunctionResultMapping ViewType="{x:Type mauiChat:FunctionResultView}" />
                <mauiChat:ErrorContentMapping ViewType="{x:Type mauiChat:ErrorView}" />
                <mauiChat:DefaultContentMapping ViewType="{x:Type mauiChat:DefaultContentView}" />
            </maui:ChatOverlayControl.ContentTemplates>
        </maui:ChatOverlayControl>
    </Grid>

</ContentPage>
