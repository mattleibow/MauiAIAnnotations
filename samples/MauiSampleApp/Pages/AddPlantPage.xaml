<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiSampleApp.Pages.AddPlantPage"
             Title="Add Plant"
             BackgroundColor="{AppThemeBinding Light={StaticResource PageBg}, Dark={StaticResource PageBgDark}}"
             Shell.BackgroundColor="{StaticResource AccentGreen}">

    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <!-- Hero -->
            <Border BackgroundColor="{StaticResource AccentGreen}"
                    Padding="24,16,24,28"
                    StrokeThickness="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="0,0,28,28" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                    <Label Text="&#x1F331;" FontSize="44" HorizontalOptions="Center" />
                    <Label Text="New Plant"
                           FontSize="26" FontAttributes="Bold"
                           TextColor="White" HorizontalOptions="Center" />
                    <Label Text="Tell us about your green friend"
                           FontSize="14" TextColor="#D4E8D4" HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Border>

            <VerticalStackLayout Spacing="16" Padding="20,24,20,24">

                <!-- Form Card -->
                <Border Padding="20"
                        BackgroundColor="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}"
                        Stroke="{AppThemeBinding Light={StaticResource CardBorder}, Dark={StaticResource CardBorderDark}}"
                        StrokeThickness="1">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="18">

                        <!-- Nickname -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Plant Nickname" FontSize="13" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}" />
                            <Border Padding="4,0" StrokeThickness="0"
                                    BackgroundColor="{AppThemeBinding Light=#F0EBE3, Dark=#33302A}">
                                <Border.StrokeShape><RoundRectangle CornerRadius="10" /></Border.StrokeShape>
                                <Entry Placeholder="e.g. My Tomatoes"
                                       Text="{Binding Nickname}"
                                       AutomationId="NicknameEntry"
                                       FontSize="15"
                                       BackgroundColor="Transparent" />
                            </Border>
                        </VerticalStackLayout>

                        <!-- Species -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Species" FontSize="13" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}" />
                            <Border Padding="4,0" StrokeThickness="0"
                                    BackgroundColor="{AppThemeBinding Light=#F0EBE3, Dark=#33302A}">
                                <Border.StrokeShape><RoundRectangle CornerRadius="10" /></Border.StrokeShape>
                                <Entry Placeholder="e.g. tomato, basil, rose"
                                       Text="{Binding Species}"
                                       AutomationId="SpeciesEntry"
                                       FontSize="15"
                                       BackgroundColor="Transparent" />
                            </Border>
                        </VerticalStackLayout>

                        <!-- Location and Indoor toggle -->
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <VerticalStackLayout Spacing="6">
                                <Label Text="Location" FontSize="13" FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}" />
                                <Border Padding="4,0" StrokeThickness="0"
                                        BackgroundColor="{AppThemeBinding Light=#F0EBE3, Dark=#33302A}">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="10" /></Border.StrokeShape>
                                    <Entry Placeholder="e.g. Back garden"
                                           Text="{Binding Location}"
                                           AutomationId="LocationEntry"
                                           FontSize="15"
                                           BackgroundColor="Transparent" />
                                </Border>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1" Spacing="6" VerticalOptions="End">
                                <Label Text="Indoor?" FontSize="13" FontAttributes="Bold"
                                       HorizontalOptions="Center"
                                       TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}" />
                                <Switch IsToggled="{Binding IsIndoor}" AutomationId="IndoorSwitch"
                                        OnColor="{StaticResource AccentGreen}"
                                        HorizontalOptions="Center" />
                            </VerticalStackLayout>
                        </Grid>

                    </VerticalStackLayout>
                </Border>

                <!-- Status -->
                <VerticalStackLayout Spacing="4" IsVisible="{Binding IsBusy}">
                    <ActivityIndicator IsRunning="{Binding IsBusy}" Color="{StaticResource AccentGreen}" />
                    <Label Text="{Binding StatusMessage}"
                           FontSize="13"
                           HorizontalOptions="Center"
                           TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}" />
                </VerticalStackLayout>

                <!-- Save -->
                <Button Text="&#x1F33F;  Add to My Garden"
                        Command="{Binding SaveCommand}"
                        BackgroundColor="{StaticResource AccentGreen}"
                        TextColor="White"
                        FontSize="16"
                        FontAttributes="Bold"
                        CornerRadius="14"
                        HeightRequest="52"
                        AutomationId="SavePlantButton" />

            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
