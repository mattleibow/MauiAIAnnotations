<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiSampleApp.Pages.DebugPage"
             Title="Debug Data"
             BackgroundColor="{AppThemeBinding Light={StaticResource PageBg}, Dark={StaticResource PageBgDark}}"
             Shell.BackgroundColor="{StaticResource AccentGreen}">

    <ScrollView>
        <VerticalStackLayout Spacing="16" Padding="20">

            <!-- Header -->
            <Label Text="🔧 Debug Data Store"
                   FontSize="24" FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />

            <!-- Species Profiles -->
            <Label Text="Species Profiles" FontSize="18" FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
            <CollectionView ItemsSource="{Binding SpeciesProfiles}"
                            EmptyView="No species profiles stored.">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="12" Margin="0,0,0,6"
                                BackgroundColor="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}"
                                Stroke="{AppThemeBinding Light={StaticResource CardBorder}, Dark={StaticResource CardBorderDark}}"
                                StrokeThickness="1">
                            <Border.StrokeShape><RoundRectangle CornerRadius="10" /></Border.StrokeShape>
                            <Label Text="{Binding .}" FontSize="12" FontFamily="monospace"
                                   TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Plants -->
            <Label Text="Plants" FontSize="18" FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
            <CollectionView ItemsSource="{Binding Plants}"
                            EmptyView="No plants stored.">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="12" Margin="0,0,0,6"
                                BackgroundColor="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}"
                                Stroke="{AppThemeBinding Light={StaticResource CardBorder}, Dark={StaticResource CardBorderDark}}"
                                StrokeThickness="1">
                            <Border.StrokeShape><RoundRectangle CornerRadius="10" /></Border.StrokeShape>
                            <Label Text="{Binding .}" FontSize="12" FontFamily="monospace"
                                   TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Care Events -->
            <Label Text="Care Events" FontSize="18" FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
            <CollectionView ItemsSource="{Binding CareEvents}"
                            EmptyView="No care events stored.">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="12" Margin="0,0,0,6"
                                BackgroundColor="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}"
                                Stroke="{AppThemeBinding Light={StaticResource CardBorder}, Dark={StaticResource CardBorderDark}}"
                                StrokeThickness="1">
                            <Border.StrokeShape><RoundRectangle CornerRadius="10" /></Border.StrokeShape>
                            <Label Text="{Binding .}" FontSize="12" FontFamily="monospace"
                                   TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Clear All -->
            <Button Text="🗑️ Clear All Data"
                    Clicked="OnClearAllClicked"
                    AutomationId="ClearAllButton"
                    BackgroundColor="{StaticResource Danger}"
                    TextColor="White"
                    FontSize="16"
                    FontAttributes="Bold"
                    CornerRadius="14"
                    HeightRequest="50"
                    Margin="0,12,0,0" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
