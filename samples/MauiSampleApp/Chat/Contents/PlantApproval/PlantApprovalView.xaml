<?xml version="1.0" encoding="utf-8" ?>
<mauiChat:ContentContextView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                             xmlns:local="clr-namespace:MauiSampleApp.Chat"
                             xmlns:mauiChat="clr-namespace:MauiAIAnnotations.Maui.Chat;assembly=MauiAIAnnotations.Maui"
                             x:Class="MauiSampleApp.Chat.PlantApprovalView"
                             x:Name="This">

    <!-- Content-only: no header, no buttons. The library wrapper provides those. -->
    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto"
          ColumnDefinitions="90,*"
          RowSpacing="8"
          ColumnSpacing="8"
          BindingContext="{Binding ViewModel, Source={x:Reference This}}"
          x:DataType="local:PlantApprovalViewModel">
        <Label Grid.ColumnSpan="2"
               Text="Review the proposed plant details. If something should change, reject and ask again."
               FontSize="12"
               LineBreakMode="WordWrap"
               TextColor="{AppThemeBinding Light=#7A7062, Dark=#A69E90}" />

        <Label Grid.Row="1"
               Text="Nickname:"
               VerticalOptions="Center"
               FontSize="13"
               FontAttributes="Bold"
               TextColor="{AppThemeBinding Light=#7A7062, Dark=#A69E90}" />
        <Border Grid.Row="1"
                Grid.Column="1"
                Padding="12,10"
                AutomationId="ApprovalNicknameEntry"
                BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#2A2721}"
                Stroke="{AppThemeBinding Light=#E8E0D4, Dark=#4A4337}"
                StrokeThickness="1">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="10" />
            </Border.StrokeShape>
            <Label Text="{Binding NicknameDisplay}"
                   FontSize="13"
                   TextColor="{AppThemeBinding Light=#2C2416, Dark=#EDE8DF}" />
        </Border>

        <Label Grid.Row="2"
               Text="Species:"
               VerticalOptions="Center"
               FontSize="13"
               FontAttributes="Bold"
               TextColor="{AppThemeBinding Light=#7A7062, Dark=#A69E90}" />
        <Border Grid.Row="2"
                Grid.Column="1"
                Padding="12,10"
                AutomationId="ApprovalSpeciesEntry"
                BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#2A2721}"
                Stroke="{AppThemeBinding Light=#E8E0D4, Dark=#4A4337}"
                StrokeThickness="1">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="10" />
            </Border.StrokeShape>
            <Label Text="{Binding SpeciesDisplay}"
                   FontSize="13"
                   TextColor="{AppThemeBinding Light=#2C2416, Dark=#EDE8DF}" />
        </Border>

        <Label Grid.Row="3"
               Text="Location:"
               VerticalOptions="Center"
               FontSize="13"
               FontAttributes="Bold"
               TextColor="{AppThemeBinding Light=#7A7062, Dark=#A69E90}" />
        <Border Grid.Row="3"
                Grid.Column="1"
                Padding="12,10"
                AutomationId="ApprovalLocationEntry"
                BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#2A2721}"
                Stroke="{AppThemeBinding Light=#E8E0D4, Dark=#4A4337}"
                StrokeThickness="1">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="10" />
            </Border.StrokeShape>
            <Label Text="{Binding LocationDisplay}"
                   FontSize="13"
                   TextColor="{AppThemeBinding Light=#2C2416, Dark=#EDE8DF}" />
        </Border>

        <Label Grid.Row="4"
               Text="Indoor:"
               VerticalOptions="Center"
               FontSize="13"
               FontAttributes="Bold"
               TextColor="{AppThemeBinding Light=#7A7062, Dark=#A69E90}" />
        <Border Grid.Row="4"
                Grid.Column="1"
                Padding="12,10"
                AutomationId="ApprovalIndoorSwitch"
                BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#2A2721}"
                Stroke="{AppThemeBinding Light=#E8E0D4, Dark=#4A4337}"
                StrokeThickness="1">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="10" />
            </Border.StrokeShape>
            <Label Text="{Binding IndoorDisplay}"
                   FontSize="13"
                   TextColor="{AppThemeBinding Light=#2C2416, Dark=#EDE8DF}" />
        </Border>
    </Grid>

</mauiChat:ContentContextView>
