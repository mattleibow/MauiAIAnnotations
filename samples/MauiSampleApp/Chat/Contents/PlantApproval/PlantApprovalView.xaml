<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:MauiSampleApp.Chat"
             x:Class="MauiSampleApp.Chat.PlantApprovalView"
             x:DataType="local:PlantApprovalViewModel">

    <!-- Content-only: no header, no buttons. The library wrapper provides those. -->
    <Grid RowDefinitions="Auto,Auto,Auto,Auto" ColumnDefinitions="90,*" RowSpacing="8" ColumnSpacing="8">
        <Label Text="Nickname:" VerticalOptions="Center" FontSize="13" FontAttributes="Bold"
               TextColor="{AppThemeBinding Light=#7A7062, Dark=#A69E90}" />
        <Entry x:Name="NicknameEntry" Grid.Column="1" Text="{Binding Nickname}" FontSize="13"
               AutomationId="ApprovalNicknameEntry"
               BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#2A2721}" />

        <Label Grid.Row="1" Text="Species:" VerticalOptions="Center" FontSize="13" FontAttributes="Bold"
               TextColor="{AppThemeBinding Light=#7A7062, Dark=#A69E90}" />
        <Entry x:Name="SpeciesEntry" Grid.Row="1" Grid.Column="1" Text="{Binding Species}" FontSize="13"
               AutomationId="ApprovalSpeciesEntry"
               BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#2A2721}" />

        <Label Grid.Row="2" Text="Location:" VerticalOptions="Center" FontSize="13" FontAttributes="Bold"
               TextColor="{AppThemeBinding Light=#7A7062, Dark=#A69E90}" />
        <Entry x:Name="LocationEntry" Grid.Row="2" Grid.Column="1" Text="{Binding Location}" FontSize="13"
               AutomationId="ApprovalLocationEntry"
               BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#2A2721}" />

        <Label Grid.Row="3" Text="Indoor:" VerticalOptions="Center" FontSize="13" FontAttributes="Bold"
               TextColor="{AppThemeBinding Light=#7A7062, Dark=#A69E90}" />
        <Switch x:Name="IndoorSwitch" Grid.Row="3" Grid.Column="1" IsToggled="{Binding IsIndoor}"
                AutomationId="ApprovalIndoorSwitch"
                OnColor="#5B8C5A" />
    </Grid>

</ContentView>
