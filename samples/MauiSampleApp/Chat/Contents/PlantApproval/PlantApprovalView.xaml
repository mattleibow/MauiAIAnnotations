<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:MauiSampleApp.Chat"
             x:Class="MauiSampleApp.Chat.PlantApprovalView"
             x:DataType="local:PlantApprovalViewModel">
    <Border Padding="14,12" Margin="0,6"
            HorizontalOptions="Fill"
            BackgroundColor="{AppThemeBinding Light=#FFF8E1, Dark=#302A18}"
            Stroke="{AppThemeBinding Light=#E8D5A0, Dark=#5A4D2A}"
            StrokeThickness="1">
        <Border.StrokeShape><RoundRectangle CornerRadius="14" /></Border.StrokeShape>
        <VerticalStackLayout Spacing="10">
            <!-- Header -->
            <HorizontalStackLayout Spacing="8">
                <Label Text="🪴" FontSize="18" VerticalOptions="Center" />
                <Label Text="Add Plant — Review &amp; Approve" FontSize="15" FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light=#8B6F00, Dark=#E8C840}"
                       VerticalOptions="Center" />
            </HorizontalStackLayout>

            <!-- Editable fields -->
            <Grid RowDefinitions="Auto,Auto,Auto,Auto" ColumnDefinitions="90,*" RowSpacing="8" ColumnSpacing="8">
                <Label Text="Nickname:" VerticalOptions="Center" FontSize="13" FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light=#7A7062, Dark=#A69E90}" />
                <Entry Grid.Column="1" Text="{Binding Nickname}" FontSize="13"
                       AutomationId="ApprovalNicknameEntry"
                       BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#2A2721}" />

                <Label Grid.Row="1" Text="Species:" VerticalOptions="Center" FontSize="13" FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light=#7A7062, Dark=#A69E90}" />
                <Entry Grid.Row="1" Grid.Column="1" Text="{Binding Species}" FontSize="13"
                       AutomationId="ApprovalSpeciesEntry"
                       BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#2A2721}" />

                <Label Grid.Row="2" Text="Location:" VerticalOptions="Center" FontSize="13" FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light=#7A7062, Dark=#A69E90}" />
                <Entry Grid.Row="2" Grid.Column="1" Text="{Binding Location}" FontSize="13"
                       AutomationId="ApprovalLocationEntry"
                       BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#2A2721}" />

                <Label Grid.Row="3" Text="Indoor:" VerticalOptions="Center" FontSize="13" FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light=#7A7062, Dark=#A69E90}" />
                <Switch Grid.Row="3" Grid.Column="1" IsToggled="{Binding IsIndoor}"
                        AutomationId="ApprovalIndoorSwitch"
                        OnColor="#5B8C5A" />
            </Grid>

            <!-- Approve / Reject buttons -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <Button Text="✅ Add Plant"
                        AutomationId="ApproveToolButton"
                        Clicked="OnApproveClicked"
                        BackgroundColor="#5B8C5A"
                        TextColor="White"
                        FontSize="14" FontAttributes="Bold"
                        CornerRadius="10" HeightRequest="40" />
                <Button Grid.Column="1" Text="❌ Cancel"
                        AutomationId="RejectToolButton"
                        Clicked="OnRejectClicked"
                        BackgroundColor="#C75050"
                        TextColor="White"
                        FontSize="14" FontAttributes="Bold"
                        CornerRadius="10" HeightRequest="40" />
            </Grid>
        </VerticalStackLayout>
    </Border>
</ContentView>
