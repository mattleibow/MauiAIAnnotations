<?xml version="1.0" encoding="utf-8" ?>
<mauiChat:ContentContextView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                             xmlns:local="clr-namespace:MauiSampleApp.Chat"
                             xmlns:mauiChat="clr-namespace:Microsoft.Extensions.AI.Maui.Chat;assembly=Microsoft.Extensions.AI.Maui"
                             x:Class="MauiSampleApp.Chat.PlantApprovalView"
                             x:Name="This">

    <!-- Content-only: no header, no buttons. The library wrapper provides those. -->
    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto"
          ColumnDefinitions="90,*"
          RowSpacing="8"
          ColumnSpacing="8"
          BindingContext="{Binding ViewModel, Source={x:Reference This}}"
          x:DataType="local:PlantApprovalViewModel">
        <Label Grid.ColumnSpan="2"
               Text="Review or edit the proposed plant details before approving."
               FontSize="12"
               LineBreakMode="WordWrap"
               TextColor="{AppThemeBinding Light=#7A7062, Dark=#A69E90}" />

        <Label Grid.Row="1"
               Text="Nickname:"
               VerticalOptions="Center"
               FontSize="13"
               FontAttributes="Bold"
               TextColor="{AppThemeBinding Light=#7A7062, Dark=#A69E90}" />
        <Border Grid.Row="1"
                Grid.Column="1"
                Padding="8,2"
                BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#2A2721}"
                Stroke="{AppThemeBinding Light=#E8E0D4, Dark=#4A4337}"
                StrokeThickness="1">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="10" />
            </Border.StrokeShape>
            <Entry Text="{Binding Nickname}"
                   Placeholder="Plant nickname"
                   ClearButtonVisibility="WhileEditing"
                   AutomationId="ApprovalNicknameEntry"
                   FontSize="13"
                   TextColor="{AppThemeBinding Light=#2C2416, Dark=#EDE8DF}"
                   PlaceholderColor="{AppThemeBinding Light=#9A907F, Dark=#8C8478}"
                   BackgroundColor="Transparent" />
        </Border>

        <Label Grid.Row="2"
               Text="Species:"
               VerticalOptions="Center"
               FontSize="13"
               FontAttributes="Bold"
               TextColor="{AppThemeBinding Light=#7A7062, Dark=#A69E90}" />
        <Border Grid.Row="2"
                Grid.Column="1"
                Padding="8,2"
                BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#2A2721}"
                Stroke="{AppThemeBinding Light=#E8E0D4, Dark=#4A4337}"
                StrokeThickness="1">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="10" />
            </Border.StrokeShape>
            <Entry Text="{Binding Species}"
                   Placeholder="Species"
                   ClearButtonVisibility="WhileEditing"
                   AutomationId="ApprovalSpeciesEntry"
                   FontSize="13"
                   TextColor="{AppThemeBinding Light=#2C2416, Dark=#EDE8DF}"
                   PlaceholderColor="{AppThemeBinding Light=#9A907F, Dark=#8C8478}"
                   BackgroundColor="Transparent" />
        </Border>

        <Label Grid.Row="3"
               Text="Location:"
               VerticalOptions="Center"
               FontSize="13"
               FontAttributes="Bold"
               TextColor="{AppThemeBinding Light=#7A7062, Dark=#A69E90}" />
        <Border Grid.Row="3"
                Grid.Column="1"
                Padding="8,2"
                BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#2A2721}"
                Stroke="{AppThemeBinding Light=#E8E0D4, Dark=#4A4337}"
                StrokeThickness="1">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="10" />
            </Border.StrokeShape>
            <Entry Text="{Binding Location}"
                   Placeholder="Location"
                   ClearButtonVisibility="WhileEditing"
                   AutomationId="ApprovalLocationEntry"
                   FontSize="13"
                   TextColor="{AppThemeBinding Light=#2C2416, Dark=#EDE8DF}"
                   PlaceholderColor="{AppThemeBinding Light=#9A907F, Dark=#8C8478}"
                   BackgroundColor="Transparent" />
        </Border>

        <Label Grid.Row="4"
               Text="Indoor:"
               VerticalOptions="Center"
               FontSize="13"
               FontAttributes="Bold"
               TextColor="{AppThemeBinding Light=#7A7062, Dark=#A69E90}" />
        <Border Grid.Row="4"
                Grid.Column="1"
                Padding="12,8"
                BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#2A2721}"
                Stroke="{AppThemeBinding Light=#E8E0D4, Dark=#4A4337}"
                StrokeThickness="1">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="10" />
            </Border.StrokeShape>
            <HorizontalStackLayout Spacing="10">
                <Switch IsToggled="{Binding IsIndoor}"
                        AutomationId="ApprovalIndoorSwitch"
                        HorizontalOptions="Start" />
                <Label Text="{Binding IndoorDisplay}"
                       VerticalOptions="Center"
                       FontSize="13"
                       TextColor="{AppThemeBinding Light=#2C2416, Dark=#EDE8DF}" />
            </HorizontalStackLayout>
        </Border>
    </Grid>

</mauiChat:ContentContextView>
