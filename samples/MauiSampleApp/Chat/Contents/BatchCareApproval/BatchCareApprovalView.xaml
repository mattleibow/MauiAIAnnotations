<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:MauiSampleApp.Chat"
             x:Class="MauiSampleApp.Chat.BatchCareApprovalView"
             x:DataType="local:BatchCareApprovalViewModel">

    <!-- Content-only: library wrapper provides header + buttons -->
    <VerticalStackLayout Spacing="8">
        <Label Text="Review the proposed care log entries. If the set should change, reject and ask again."
               FontSize="12"
               LineBreakMode="WordWrap"
               TextColor="{AppThemeBinding Light=#7A7062, Dark=#A69E90}" />

        <HorizontalStackLayout Spacing="6">
            <Label Text="Plant:"
                   FontSize="13"
                   FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light=#7A7062, Dark=#A69E90}" />
            <Label Text="{Binding PlantNicknameDisplay}"
                   FontSize="13"
                   TextColor="{AppThemeBinding Light=#2C2416, Dark=#EDE8DF}" />
        </HorizontalStackLayout>

        <Label Text="Care events to log:"
               FontSize="12"
               TextColor="{AppThemeBinding Light=#7A7062, Dark=#A69E90}" />

        <CollectionView ItemsSource="{Binding CareItems}"
                        AutomationId="BatchCareList">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="local:CareItemViewModel">
                    <Border Padding="10,8"
                            Margin="0,2"
                            BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#2A2721}"
                            Stroke="{AppThemeBinding Light=#E8E0D4, Dark=#4A4337}"
                            StrokeThickness="1">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10" />
                        </Border.StrokeShape>
                        <VerticalStackLayout Spacing="2">
                            <Label Text="{Binding EventType}"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#2C2416, Dark=#EDE8DF}" />
                            <Label Text="{Binding Notes}"
                                   IsVisible="{Binding HasNotes}"
                                   FontSize="12"
                                   TextColor="{AppThemeBinding Light=#7A7062, Dark=#A69E90}" />
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </VerticalStackLayout>

</ContentView>
