<?xml version="1.0" encoding="utf-8" ?>
<maui:ContentContextView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                         xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                         xmlns:controls="clr-namespace:MauiSampleApp.Controls"
                         xmlns:models="clr-namespace:MauiSampleApp.Core.Models;assembly=MauiSampleApp.Core"
                         xmlns:chat="clr-namespace:MauiSampleApp.Chat"
                         xmlns:maui="clr-namespace:Microsoft.Extensions.AI.Maui.Chat;assembly=Microsoft.Extensions.AI.Maui"
                         x:Name="This"
                         x:Class="MauiSampleApp.Chat.PlantResultView">
    <Grid x:Name="InnerContent" Padding="0,4">
        <VerticalStackLayout Spacing="8"
                             BindingContext="{Binding ViewModel, Source={x:Reference This}}"
                             x:DataType="chat:PlantResultViewModel">
            <Label Text="{Binding PreviewTitle}"
                   IsVisible="{Binding HasMultiplePlants}"
                   FontSize="14"
                   FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />

            <Border IsVisible="{Binding HasNoPlants}"
                    AutomationId="PlantEmptyState"
                    Padding="12,10"
                    Stroke="{AppThemeBinding Light={StaticResource CardBorder}, Dark={StaticResource CardBorderDark}}"
                    StrokeThickness="1"
                    BackgroundColor="{AppThemeBinding Light=#F6FBF5, Dark=#233226}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12" />
                </Border.StrokeShape>
                <Label Text="{Binding EmptyStateText}"
                       FontSize="13"
                       LineBreakMode="WordWrap"
                       TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}" />
            </Border>

            <ContentView IsVisible="{Binding HasSinglePlant}"
                         HorizontalOptions="Start">
                <controls:PlantCardView BindingContext="{Binding Plant}"
                                        HorizontalOptions="Start"
                                        MaximumWidthRequest="320" />
            </ContentView>

            <CollectionView ItemsSource="{Binding Plants}"
                            IsVisible="{Binding HasMultiplePlants}"
                            AutomationId="PlantPreviewList"
                            SelectionMode="None"
                            HeightRequest="118"
                            HorizontalScrollBarVisibility="Never">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Horizontal" ItemSpacing="12" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Plant">
                        <controls:PlantCardView BindingContext="{Binding .}"
                                                WidthRequest="240"
                                                Margin="0,0,4,0" />
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </Grid>
</maui:ContentContextView>
