<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:chat="clr-namespace:MauiSampleApp.Chat"
             x:Class="MauiSampleApp.Controls.ChatOverlayControl"
             x:Name="Self">

    <ContentView.Resources>
        <chat:ContentTemplateSelector x:Key="ChatTemplateSelector">
            <chat:ContentTemplateSelector.Templates>

                <!-- User text: green bubble, right-aligned -->
                <chat:TextContentMapping Role="User">
                    <chat:TextContentMapping.Template>
                        <DataTemplate x:DataType="chat:ContentContext">
                            <Grid Padding="0,4">
                                <Border Padding="12,10" MaximumWidthRequest="340"
                                        HorizontalOptions="End"
                                        BackgroundColor="{StaticResource ChatUser}"
                                        StrokeThickness="0">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="16,16,4,16" /></Border.StrokeShape>
                                    <Label Text="{Binding DisplayText}" FontSize="14" TextColor="White" />
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </chat:TextContentMapping.Template>
                </chat:TextContentMapping>

                <!-- Assistant text: light bubble, left-aligned -->
                <chat:TextContentMapping Role="Assistant">
                    <chat:TextContentMapping.Template>
                        <DataTemplate x:DataType="chat:ContentContext">
                            <Grid Padding="0,4">
                                <Border Padding="12,10" MaximumWidthRequest="340"
                                        HorizontalOptions="Start"
                                        BackgroundColor="{AppThemeBinding Light=#F0EBE3, Dark=#33302A}"
                                        StrokeThickness="0">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="16,16,16,4" /></Border.StrokeShape>
                                    <Label Text="{Binding DisplayText}" FontSize="14"
                                           TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}" />
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </chat:TextContentMapping.Template>
                </chat:TextContentMapping>

                <!-- Function call: compact gray card with tool name -->
                <chat:FunctionCallMapping>
                    <chat:FunctionCallMapping.Template>
                        <DataTemplate x:DataType="chat:ContentContext">
                            <Grid Padding="0,2">
                                <Border Padding="10,6" HorizontalOptions="Start"
                                        BackgroundColor="{AppThemeBinding Light=#E8E0D4, Dark=#2A2620}"
                                        StrokeThickness="0" Opacity="0.85">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="10" /></Border.StrokeShape>
                                    <HorizontalStackLayout Spacing="6">
                                        <Label Text="&#x2699;&#xFE0F;" FontSize="12" VerticalOptions="Center" />
                                        <Label Text="{Binding DisplayText}" FontSize="12" FontAttributes="Italic"
                                               TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}" />
                                    </HorizontalStackLayout>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </chat:FunctionCallMapping.Template>
                </chat:FunctionCallMapping>

                <!-- Function result: compact light green card -->
                <chat:FunctionResultMapping>
                    <chat:FunctionResultMapping.Template>
                        <DataTemplate x:DataType="chat:ContentContext">
                            <Grid Padding="0,2">
                                <Border Padding="10,6" HorizontalOptions="Start"
                                        BackgroundColor="{AppThemeBinding Light=#EDF6EC, Dark=#1A251A}"
                                        StrokeThickness="0" Opacity="0.85">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="10" /></Border.StrokeShape>
                                    <Label Text="{Binding DisplayText}" FontSize="11" LineBreakMode="WordWrap"
                                           MaximumWidthRequest="300"
                                           TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}" />
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </chat:FunctionResultMapping.Template>
                </chat:FunctionResultMapping>

                <!-- Error: red-tinted bubble -->
                <chat:ErrorContentMapping>
                    <chat:ErrorContentMapping.Template>
                        <DataTemplate x:DataType="chat:ContentContext">
                            <Grid Padding="0,4">
                                <Border Padding="12,10" MaximumWidthRequest="340"
                                        HorizontalOptions="Start"
                                        BackgroundColor="{AppThemeBinding Light=#FDE8E8, Dark=#2A1818}"
                                        StrokeThickness="0">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="12" /></Border.StrokeShape>
                                    <Label Text="{Binding DisplayText}" FontSize="14" TextColor="{StaticResource Danger}" />
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </chat:ErrorContentMapping.Template>
                </chat:ErrorContentMapping>

                <!-- Default fallback -->
                <chat:DefaultContentMapping>
                    <chat:DefaultContentMapping.Template>
                        <DataTemplate x:DataType="chat:ContentContext">
                            <Label Text="{Binding DisplayText}" FontSize="13" Padding="4"
                                   TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}" />
                        </DataTemplate>
                    </chat:DefaultContentMapping.Template>
                </chat:DefaultContentMapping>

            </chat:ContentTemplateSelector.Templates>
        </chat:ContentTemplateSelector>
    </ContentView.Resources>

    <Grid>
        <!-- FAB Chat Button -->
        <Button Text="💬"
                Clicked="OnOpenChatClicked"
                AutomationId="OpenChatButton"
                BackgroundColor="{StaticResource AccentGreen}"
                TextColor="White"
                FontSize="24"
                WidthRequest="56"
                HeightRequest="56"
                CornerRadius="28"
                HorizontalOptions="End"
                VerticalOptions="End"
                Margin="0,0,20,20" />

        <!-- Chat Popup Overlay -->
        <Grid x:Name="ChatOverlay"
              IsVisible="False"
              AutomationId="ChatOverlay"
              BackgroundColor="#66000000">

            <Grid.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnChatBackdropTapped" />
            </Grid.GestureRecognizers>

            <Border VerticalOptions="End"
                    HorizontalOptions="Fill"
                    HeightRequest="500"
                    Margin="12,0,12,12"
                    Padding="0"
                    InputTransparent="False"
                    Stroke="{AppThemeBinding Light={StaticResource CardBorder}, Dark={StaticResource CardBorderDark}}"
                    StrokeThickness="1"
                    BackgroundColor="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20,20,12,12" />
                </Border.StrokeShape>

                <Grid RowDefinitions="Auto,*,Auto,Auto" RowSpacing="0">
                    <!-- Chat Header -->
                    <Border Grid.Row="0"
                            BackgroundColor="{StaticResource AccentGreen}"
                            Padding="16,14"
                            StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="20,20,0,0" />
                        </Border.StrokeShape>
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="&#x1F33F; Garden Assistant"
                                   FontSize="17" FontAttributes="Bold"
                                   TextColor="White" VerticalOptions="Center" />
                            <Button Grid.Column="1" Text="&#x2715;" FontSize="16"
                                    BackgroundColor="Transparent" TextColor="#D4E8D4"
                                    Clicked="OnCloseChatClicked"
                                    AutomationId="CloseChatButton"
                                    Padding="8,4" MinimumWidthRequest="40" />
                        </Grid>
                    </Border>

                    <!-- Messages with content template selector -->
                    <CollectionView x:Name="ChatMessages"
                                    Grid.Row="1"
                                    ItemsSource="{Binding ChatVM.Messages, Source={x:Reference Self}}"
                                    ItemTemplate="{StaticResource ChatTemplateSelector}"
                                    AutomationId="ChatMessages"
                                    Margin="12,8,12,0" />

                    <!-- Busy indicator -->
                    <ActivityIndicator Grid.Row="2"
                                       IsRunning="{Binding ChatVM.IsBusy, Source={x:Reference Self}}"
                                       IsVisible="{Binding ChatVM.IsBusy, Source={x:Reference Self}}"
                                       Color="{StaticResource AccentGreen}"
                                       Margin="0,6" />

                    <!-- Input Area -->
                    <Border Grid.Row="3" Margin="12,8,12,12" Padding="6"
                            BackgroundColor="{AppThemeBinding Light=#F0EBE3, Dark=#33302A}"
                            StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14" />
                        </Border.StrokeShape>
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                            <Entry Placeholder="Ask about your plants..."
                                   Text="{Binding ChatVM.UserInput, Source={x:Reference Self}}"
                                   ReturnCommand="{Binding ChatVM.SendCommand, Source={x:Reference Self}}"
                                   AutomationId="ChatInput" FontSize="14"
                                   BackgroundColor="Transparent" />
                            <Button Grid.Column="1" Text="&#x27A4;"
                                    Command="{Binding ChatVM.SendCommand, Source={x:Reference Self}}"
                                    AutomationId="SendButton"
                                    BackgroundColor="{StaticResource AccentGreen}"
                                    TextColor="White" FontSize="16"
                                    WidthRequest="42" HeightRequest="42"
                                    CornerRadius="12" Padding="0" />
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>

</ContentView>
