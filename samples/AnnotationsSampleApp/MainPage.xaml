<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AnnotationsSampleApp.MainPage"
             x:Name="ThisPage"
             Title="Garden AI Chat"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,Auto,*,Auto" RowSpacing="0">

        <!-- Header -->
        <Border Grid.Row="0"
                BackgroundColor="#5B8C5A"
                Padding="16,14"
                StrokeThickness="0">
            <Grid ColumnDefinitions="*,Auto">
                <Label Text="🌿 Annotations Sample"
                       FontSize="20" FontAttributes="Bold"
                       TextColor="White" VerticalOptions="Center" />
                <Button Grid.Column="1"
                        Text="New Chat"
                        AutomationId="NewChatButton"
                        Clicked="OnNewChatClicked"
                        BackgroundColor="#E3F2E3"
                        TextColor="#5B8C5A"
                        FontSize="13"
                        FontAttributes="Bold"
                        CornerRadius="16"
                        Padding="12,6"
                        VerticalOptions="Center" />
            </Grid>
        </Border>

        <!-- Tool Mode Picker -->
        <Grid Grid.Row="1"
              Padding="12,8"
              ColumnDefinitions="Auto,*"
              ColumnSpacing="8"
              BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#1E1E1E}">
            <Label Text="Tools:"
                   FontSize="13"
                   FontAttributes="Bold"
                   VerticalOptions="Center" />
            <Picker Grid.Column="1"
                    x:Name="ToolModePicker"
                    AutomationId="ToolModePicker"
                    SelectedIndex="0"
                    FontSize="13"
                    SelectedIndexChanged="OnToolModeChanged">
                <Picker.ItemsSource>
                    <x:Array Type="{x:Type x:String}">
                        <x:String>All Tools</x:String>
                        <x:String>Catalog Only</x:String>
                        <x:String>Garden Management</x:String>
                    </x:Array>
                </Picker.ItemsSource>
            </Picker>
        </Grid>

        <!-- Chat Messages -->
        <ScrollView Grid.Row="2"
                    x:Name="ChatScrollView"
                    Padding="12,8">
            <VerticalStackLayout x:Name="MessagesStack"
                                 Spacing="8" />
        </ScrollView>

        <!-- Input Area -->
        <Grid x:Name="InputArea"
              Grid.Row="3"
              Padding="12,8,12,12"
              ColumnDefinitions="*,Auto"
              ColumnSpacing="8"
              BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#1E1E1E}">
            <Entry x:Name="ChatInput"
                   AutomationId="ChatInput"
                   Placeholder="Ask about plants..."
                   ReturnType="Send"
                   Completed="OnSendClicked"
                   FontSize="14" />
            <Button Grid.Column="1"
                    Text="Send"
                    AutomationId="SendButton"
                    Clicked="OnSendClicked"
                    BackgroundColor="#5B8C5A"
                    TextColor="White"
                    FontSize="14"
                    CornerRadius="8"
                    Padding="16,8"
                    VerticalOptions="Center" />
        </Grid>

        <!-- Approval Area (hidden by default) -->
        <Grid x:Name="ApprovalArea"
              Grid.Row="3"
              Padding="12,8,12,12"
              ColumnDefinitions="*,Auto,Auto"
              ColumnSpacing="8"
              IsVisible="False"
              BackgroundColor="{AppThemeBinding Light=#FFF8E1, Dark=#3E3520}">
            <Label x:Name="ApprovalLabel"
                   Text="Approve tool call?"
                   FontSize="14"
                   FontAttributes="Bold"
                   VerticalOptions="Center"
                   LineBreakMode="TailTruncation" />
            <Button Grid.Column="1"
                    Text="✅ Approve"
                    AutomationId="ApproveButton"
                    Clicked="OnApproveClicked"
                    BackgroundColor="#5B8C5A"
                    TextColor="White"
                    FontSize="14"
                    CornerRadius="8"
                    Padding="16,8"
                    VerticalOptions="Center" />
            <Button Grid.Column="2"
                    Text="❌ Reject"
                    AutomationId="RejectButton"
                    Clicked="OnRejectClicked"
                    BackgroundColor="#C62828"
                    TextColor="White"
                    FontSize="14"
                    CornerRadius="8"
                    Padding="16,8"
                    VerticalOptions="Center" />
        </Grid>

    </Grid>

</ContentPage>
