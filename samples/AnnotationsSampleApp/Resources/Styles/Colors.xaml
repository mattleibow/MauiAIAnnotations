<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Gardening App Theme - Warm Organic -->
    <Color x:Key="Primary">#5B8C5A</Color>
    <Color x:Key="PrimaryDark">#3D6B3D</Color>
    <Color x:Key="PrimaryDarkText">#D4E8D4</Color>
    <Color x:Key="Secondary">#C9A96E</Color>
    <Color x:Key="SecondaryDarkText">#C9A96E</Color>
    <Color x:Key="Tertiary">#8B6F47</Color>

    <Color x:Key="White">#FFFFFF</Color>
    <Color x:Key="Black">#000000</Color>

    <!-- App-specific colors -->
    <Color x:Key="PageBg">#F7F3ED</Color>
    <Color x:Key="PageBgDark">#1C1B18</Color>
    <Color x:Key="CardBg">#FFFFFF</Color>
    <Color x:Key="CardBgDark">#2A2721</Color>
    <Color x:Key="CardBorder">#E8E0D4</Color>
    <Color x:Key="CardBorderDark">#3D3930</Color>
    <Color x:Key="TextPrimary">#2C2416</Color>
    <Color x:Key="TextPrimaryDark">#EDE8DF</Color>
    <Color x:Key="TextSecondary">#7A7062</Color>
    <Color x:Key="TextSecondaryDark">#A69E90</Color>
    <Color x:Key="AccentGreen">#5B8C5A</Color>
    <Color x:Key="AccentOchre">#C9A96E</Color>
    <Color x:Key="AccentSage">#8CAD7E</Color>
    <Color x:Key="BadgeIndoor">#E8D5A3</Color>
    <Color x:Key="BadgeOutdoor">#B5D8B2</Color>
    <Color x:Key="ChatUser">#5B8C5A</Color>
    <Color x:Key="ChatAI">#C9A96E</Color>
    <Color x:Key="Danger">#C75050</Color>

    <!-- Gray scale -->
    <Color x:Key="Gray100">#E8E0D4</Color>
    <Color x:Key="Gray200">#D4CABF</Color>
    <Color x:Key="Gray300">#B5ADA2</Color>
    <Color x:Key="Gray400">#968E83</Color>
    <Color x:Key="Gray500">#7A7062</Color>
    <Color x:Key="Gray600">#4A4238</Color>
    <Color x:Key="Gray900">#2C2416</Color>
    <Color x:Key="Gray950">#1C1B18</Color>

    <Color x:Key="Magenta">#D600AA</Color>
    <Color x:Key="MidnightBlue">#190649</Color>
    <Color x:Key="OffBlack">#1f1f1f</Color>

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource Secondary}"/>
    <SolidColorBrush x:Key="TertiaryBrush" Color="{StaticResource Tertiary}"/>
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}"/>
    <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource Black}"/>

    <SolidColorBrush x:Key="Gray100Brush" Color="{StaticResource Gray100}"/>
    <SolidColorBrush x:Key="Gray200Brush" Color="{StaticResource Gray200}"/>
    <SolidColorBrush x:Key="Gray300Brush" Color="{StaticResource Gray300}"/>
    <SolidColorBrush x:Key="Gray400Brush" Color="{StaticResource Gray400}"/>
    <SolidColorBrush x:Key="Gray500Brush" Color="{StaticResource Gray500}"/>
    <SolidColorBrush x:Key="Gray600Brush" Color="{StaticResource Gray600}"/>
    <SolidColorBrush x:Key="Gray900Brush" Color="{StaticResource Gray900}"/>
    <SolidColorBrush x:Key="Gray950Brush" Color="{StaticResource Gray950}"/>
</ResourceDictionary>